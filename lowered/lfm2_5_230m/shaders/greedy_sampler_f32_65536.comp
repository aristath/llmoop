#version 450

layout(local_size_x = 64, local_size_y = 1, local_size_z = 1) in;

layout(set = 0, binding = 0) readonly buffer Logits {
    float values[];
} logits;

layout(set = 0, binding = 1) buffer SamplerOutput {
    uint words[];
} sampler_output;

const uint VOCAB_SIZE = 65536u;

void main() {
    if (gl_GlobalInvocationID.x != 0u) {
        return;
    }

    uint best_token_id = 0u;
    float best_logit = logits.values[0];
    for (uint token_id = 1u; token_id < VOCAB_SIZE; token_id = token_id + 1u) {
        float candidate = logits.values[token_id];
        if (candidate > best_logit) {
            best_token_id = token_id;
            best_logit = candidate;
        }
    }

    sampler_output.words[0] = best_token_id;
    sampler_output.words[1] = floatBitsToUint(best_logit);
    sampler_output.words[2] = 0u;
    sampler_output.words[3] = 0u;
}
