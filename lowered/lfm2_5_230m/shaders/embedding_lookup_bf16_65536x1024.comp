#version 450

layout(local_size_x = 256, local_size_y = 1, local_size_z = 1) in;

layout(push_constant) uniform TokenSelect {
    uint token_id;
} token_select;

layout(set = 0, binding = 0) readonly buffer EmbeddingWeight {
    uint words[];
} embedding_weight;

layout(set = 0, binding = 1) buffer OutputFrame {
    uint words[];
} output_frame;

const uint VOCAB_SIZE = 65536u;
const uint FRAME_WORDS = 512u;

void main() {
    uint word_index = gl_GlobalInvocationID.x;
    if (word_index >= FRAME_WORDS) {
        return;
    }
    if (token_select.token_id >= VOCAB_SIZE) {
        return;
    }

    uint source_base = token_select.token_id * FRAME_WORDS;
    output_frame.words[word_index] = embedding_weight.words[source_base + word_index];
}
