#version 450

layout(local_size_x = 64, local_size_y = 1, local_size_z = 1) in;

layout(set = 0, binding = 0) readonly buffer InputFrame {
    uint words[];
} input_frame;

layout(set = 0, binding = 1) buffer OutputFrame {
    uint words[];
} output_frame;

layout(set = 0, binding = 2) readonly buffer Weight {
    uint words[];
} weight;

const uint HIDDEN_SIZE = 1024u;

float bf16_to_f32(uint value) {
    return uintBitsToFloat((value & 0xffffu) << 16);
}

uint f32_to_bf16(float value) {
    uint bits = floatBitsToUint(value);
    uint lsb = (bits >> 16) & 1u;
    uint rounding_bias = 0x7fffu + lsb;
    return (bits + rounding_bias) >> 16;
}

float read_input(uint index) {
    uint packed = input_frame.words[index >> 1];
    uint value = ((index & 1u) == 0u) ? (packed & 0xffffu) : (packed >> 16);
    return bf16_to_f32(value);
}

float read_weight(uint index) {
    uint packed = weight.words[index >> 1];
    uint value = ((index & 1u) == 0u) ? (packed & 0xffffu) : (packed >> 16);
    return bf16_to_f32(value);
}

void main() {
    if (gl_GlobalInvocationID.x != 0u) {
        return;
    }

    float sum_squares = 0.0;
    for (uint index = 0u; index < HIDDEN_SIZE; index = index + 1u) {
        float value = read_input(index);
        sum_squares = sum_squares + value * value;
    }
    float inv_rms = inversesqrt((sum_squares / float(HIDDEN_SIZE)) + 0.000001);

    for (uint index = 0u; index < HIDDEN_SIZE; index = index + 2u) {
        float lo = read_input(index) * inv_rms * read_weight(index);
        float hi = read_input(index + 1u) * inv_rms * read_weight(index + 1u);
        output_frame.words[index >> 1] = (f32_to_bf16(hi) << 16) | f32_to_bf16(lo);
    }
}
