#version 450

layout(local_size_x = 64, local_size_y = 1, local_size_z = 1) in;

layout(set = 0, binding = 0) readonly buffer InputFrame {
    uint words[];
} input_frame;

layout(set = 0, binding = 1) buffer OutputA {
    uint words[];
} output_a;

layout(set = 0, binding = 2) buffer OutputB {
    uint words[];
} output_b;

layout(set = 0, binding = 3) buffer OutputC {
    uint words[];
} output_c;

const uint CHUNK_WORDS = 512u;

void main() {
    if (gl_GlobalInvocationID.x != 0u) {
        return;
    }

    for (uint word_index = 0u; word_index < CHUNK_WORDS; word_index = word_index + 1u) {
        output_a.words[word_index] = input_frame.words[word_index];
        output_b.words[word_index] = input_frame.words[CHUNK_WORDS + word_index];
        output_c.words[word_index] = input_frame.words[(2u * CHUNK_WORDS) + word_index];
    }
}
