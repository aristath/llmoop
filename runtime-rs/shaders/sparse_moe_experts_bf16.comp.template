#version 450

layout(local_size_x = 256, local_size_y = 1, local_size_z = 1) in;

layout(set = 0, binding = 0) readonly buffer HiddenInput {
    uint words[];
} hidden_input;

layout(set = 0, binding = 1) readonly buffer RoutingWeights {
    uint words[];
} routing_weights;

layout(set = 0, binding = 2) buffer ExpertOutputs {
    uint words[];
} expert_outputs;

layout(set = 0, binding = 3) readonly buffer ExpertInputWeight {
    uint words[];
} expert_input_weight;

layout(set = 0, binding = 4) readonly buffer ExpertOutputWeight {
    uint words[];
} expert_output_weight;

const uint HIDDEN_SIZE = {{HIDDEN_SIZE}}u;
const uint INTERMEDIATE_SIZE = {{INTERMEDIATE_SIZE}}u;
const uint NUM_EXPERTS = {{NUM_EXPERTS}}u;
const uint EXPERTS_PER_TOKEN = {{EXPERTS_PER_TOKEN}}u;
const uint HIDDEN_WORDS = HIDDEN_SIZE / 2u;
const uint INTERMEDIATE_WORDS = INTERMEDIATE_SIZE / 2u;

shared uint intermediate_words[INTERMEDIATE_WORDS];

float bf16_to_f32(uint value) {
    return uintBitsToFloat((value & 0xffffu) << 16);
}

uint f32_to_bf16(float value) {
    uint bits = floatBitsToUint(value);
    uint lsb = (bits >> 16) & 1u;
    return (bits + 0x7fffu + lsb) >> 16;
}

float round_bf16(float value) {
    return bf16_to_f32(f32_to_bf16(value));
}

float read_hidden(uint index) {
    uint packed = hidden_input.words[index >> 1u];
    return bf16_to_f32((index & 1u) == 0u ? packed : packed >> 16);
}

float read_route(uint expert) {
    uint packed = routing_weights.words[expert >> 1u];
    return bf16_to_f32((expert & 1u) == 0u ? packed : packed >> 16);
}

float read_expert_input(uint expert, uint row, uint column) {
    uint index = (expert * 2u * INTERMEDIATE_SIZE + row) * HIDDEN_SIZE + column;
    uint packed = expert_input_weight.words[index >> 1u];
    return bf16_to_f32((index & 1u) == 0u ? packed : packed >> 16);
}

float read_intermediate(uint index) {
    uint packed = intermediate_words[index >> 1u];
    return bf16_to_f32((index & 1u) == 0u ? packed : packed >> 16);
}

float read_expert_output(uint expert, uint row, uint column) {
    uint index = (expert * HIDDEN_SIZE + row) * INTERMEDIATE_SIZE + column;
    uint packed = expert_output_weight.words[index >> 1u];
    return bf16_to_f32((index & 1u) == 0u ? packed : packed >> 16);
}

float expert_input_linear(uint expert, uint row) {
    float sum = 0.0;
    for (uint column = 0u; column < HIDDEN_SIZE; column++) {
        sum = fma(read_hidden(column), read_expert_input(expert, row, column), sum);
    }
    return round_bf16(sum);
}

float expert_output_linear(uint expert, uint row) {
    float sum = 0.0;
    for (uint column = 0u; column < INTERMEDIATE_SIZE; column++) {
        sum = fma(
            read_intermediate(column),
            read_expert_output(expert, row, column),
            sum
        );
    }
    return round_bf16(sum);
}

void main() {
    uint expert = gl_WorkGroupID.x;
    uint lane = gl_LocalInvocationID.x;
    if (expert >= NUM_EXPERTS) {
        return;
    }
    float route_weight = read_route(expert);
    uint output_base = expert * HIDDEN_WORDS;
    if (route_weight == 0.0) {
        for (uint word = lane; word < HIDDEN_WORDS; word += 256u) {
            expert_outputs.words[output_base + word] = 0u;
        }
        return;
    }

    for (uint word = lane; word < INTERMEDIATE_WORDS; word += 256u) {
        uint first = word * 2u;
        float gate_lo = expert_input_linear(expert, first);
        float gate_hi = expert_input_linear(expert, first + 1u);
        float up_lo = expert_input_linear(expert, INTERMEDIATE_SIZE + first);
        float up_hi = expert_input_linear(expert, INTERMEDIATE_SIZE + first + 1u);
        float hidden_lo = round_bf16(
            round_bf16(gate_lo / (1.0 + exp(-gate_lo))) * up_lo
        );
        float hidden_hi = round_bf16(
            round_bf16(gate_hi / (1.0 + exp(-gate_hi))) * up_hi
        );
        intermediate_words[word] =
            (f32_to_bf16(hidden_hi) << 16) | f32_to_bf16(hidden_lo);
    }
    barrier();

    for (uint word = lane; word < HIDDEN_WORDS; word += 256u) {
        uint first = word * 2u;
        float lo = round_bf16(
            expert_output_linear(expert, first) * route_weight
        );
        float hi = round_bf16(
            expert_output_linear(expert, first + 1u) * route_weight
        );
        expert_outputs.words[output_base + word] =
            (f32_to_bf16(hi) << 16) | f32_to_bf16(lo);
    }
}
