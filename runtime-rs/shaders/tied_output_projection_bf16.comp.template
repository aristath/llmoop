#version 450

#extension GL_KHR_shader_subgroup_basic : require
#extension GL_KHR_shader_subgroup_arithmetic : require

layout(local_size_x = 64, local_size_y = 1, local_size_z = 1) in;

layout(set = 0, binding = 0) readonly buffer NormalizedFrame {
    uint words[];
} normalized_frame;

layout(set = 0, binding = 1) readonly buffer EmbeddingWeight {
    uint words[];
} embedding_weight;

layout(set = 0, binding = 2) buffer Logits {
    float values[];
} logits;

const uint INPUT_SIZE = {{INPUT_SIZE}}u;
const uint VOCAB_SIZE = {{VOCAB_SIZE}}u;
const uint INPUT_WORDS = (INPUT_SIZE + 1u) / 2u;
const uint OUTPUT_WORDS = (VOCAB_SIZE + 1u) / 2u;
const float OUTPUT_SCALE = {{OUTPUT_SCALE}};

shared float subgroup_lo[64];
shared float subgroup_hi[64];

float bf16_to_f32(uint value) {
    return uintBitsToFloat((value & 0xffffu) << 16);
}

void store_result(uint output_word, uint lo_row, uint hi_row, float lo_sum, float hi_sum) {
    logits.values[lo_row] = lo_sum * OUTPUT_SCALE;
    if (hi_row < VOCAB_SIZE) {
        logits.values[hi_row] = hi_sum * OUTPUT_SCALE;
    }
}

void main() {
    uint output_word = gl_WorkGroupID.x;
    uint lane = gl_LocalInvocationID.x;
    uint lo_row = output_word * 2u;
    uint hi_row = lo_row + 1u;
    uint lo_weight_offset = lo_row * INPUT_WORDS;
    uint hi_weight_offset = hi_row * INPUT_WORDS;

    float lo_sum = 0.0;
    float hi_sum = 0.0;
    if (output_word < OUTPUT_WORDS) {
        for (uint column_word = lane; column_word < INPUT_WORDS; column_word += 64u) {
            uint input_pair = normalized_frame.words[column_word];
            float input_lo = bf16_to_f32(input_pair);
            float input_hi = bf16_to_f32(input_pair >> 16);

            uint lo_weight_pair = embedding_weight.words[lo_weight_offset + column_word];
            lo_sum = fma(input_lo, bf16_to_f32(lo_weight_pair), lo_sum);
            lo_sum = fma(input_hi, bf16_to_f32(lo_weight_pair >> 16), lo_sum);
            if (hi_row < VOCAB_SIZE) {
                uint hi_weight_pair = embedding_weight.words[hi_weight_offset + column_word];
                hi_sum = fma(input_lo, bf16_to_f32(hi_weight_pair), hi_sum);
                hi_sum = fma(input_hi, bf16_to_f32(hi_weight_pair >> 16), hi_sum);
            }
        }
    }

    lo_sum = subgroupAdd(lo_sum);
    hi_sum = subgroupAdd(hi_sum);
    if (gl_NumSubgroups == 1u) {
        if (gl_SubgroupInvocationID == 0u && output_word < OUTPUT_WORDS) {
            store_result(output_word, lo_row, hi_row, lo_sum, hi_sum);
        }
        return;
    }

    if (gl_SubgroupInvocationID == 0u) {
        subgroup_lo[gl_SubgroupID] = lo_sum;
        subgroup_hi[gl_SubgroupID] = hi_sum;
    }
    barrier();

    if (lane == 0u && output_word < OUTPUT_WORDS) {
        float lo_total = 0.0;
        float hi_total = 0.0;
        for (uint subgroup = 0u; subgroup < gl_NumSubgroups; subgroup++) {
            lo_total += subgroup_lo[subgroup];
            hi_total += subgroup_hi[subgroup];
        }
        store_result(output_word, lo_row, hi_row, lo_total, hi_total);
    }
}
