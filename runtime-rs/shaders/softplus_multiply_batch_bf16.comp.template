#version 450

layout(local_size_x = 64, local_size_y = 1, local_size_z = 1) in;

layout(set = 0, binding = 0) readonly buffer ValueInputFrames {
    uint words[];
} value_input_frames;

layout(set = 0, binding = 1) readonly buffer GateInputFrames {
    uint words[];
} gate_input_frames;

layout(set = 0, binding = 2) buffer OutputFrames {
    uint words[];
} output_frames;

layout(push_constant) uniform BatchControl { uint batch_width; } batch_control;

const uint BATCH_TILE_WIDTH = {{BATCH_TILE_WIDTH}}u;
const uint QUERY_HEADS = {{QUERY_HEADS}}u;
const uint HEAD_WIDTH = {{HEAD_WIDTH}}u;
const bool PER_HEAD = {{PER_HEAD}} != 0;
const uint FRAME_WORDS = QUERY_HEADS * HEAD_WIDTH / 2u;
const uint GATE_VALUES = PER_HEAD ? QUERY_HEADS : QUERY_HEADS * HEAD_WIDTH;
const uint GATE_WORDS = (GATE_VALUES + 1u) / 2u;

float bf16_to_f32(uint value) {
    return uintBitsToFloat((value & 0xffffu) << 16);
}

uint f32_to_bf16(float value) {
    uint bits = floatBitsToUint(value);
    uint lsb = (bits >> 16) & 1u;
    return (bits + 0x7fffu + lsb) >> 16;
}

float read_gate(uint batch_index, uint element) {
    uint index = PER_HEAD ? element / HEAD_WIDTH : element;
    uint packed = gate_input_frames.words[batch_index * GATE_WORDS + (index >> 1u)];
    return bf16_to_f32((index & 1u) == 0u ? packed : packed >> 16);
}

float softplus(float value) {
    return value > 20.0 ? value : log(1.0 + exp(value));
}

void main() {
    uint batch_start = gl_WorkGroupID.y * BATCH_TILE_WIDTH;
    for (uint word_in_frame = gl_LocalInvocationID.x;
         word_in_frame < FRAME_WORDS;
         word_in_frame += 64u) {
        for (uint batch_lane = 0u; batch_lane < BATCH_TILE_WIDTH; batch_lane++) {
            uint batch_index = batch_start + batch_lane;
            if (batch_index >= batch_control.batch_width) continue;
            uint word_index = batch_index * FRAME_WORDS + word_in_frame;
            uint value = value_input_frames.words[word_index];
            uint lo_element = word_in_frame * 2u;
            uint hi_element = lo_element + 1u;
            float lo = bf16_to_f32(value)
                * softplus(read_gate(batch_index, lo_element));
            float hi = bf16_to_f32(value >> 16)
                * softplus(read_gate(batch_index, hi_element));
            output_frames.words[word_index] =
                (f32_to_bf16(hi) << 16u) | f32_to_bf16(lo);
        }
    }
}
