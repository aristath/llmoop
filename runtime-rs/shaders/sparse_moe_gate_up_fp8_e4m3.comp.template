#version 460

#extension GL_KHR_shader_subgroup_basic : require
#extension GL_KHR_shader_subgroup_arithmetic : require
#extension GL_KHR_shader_subgroup_clustered : require
#extension GL_EXT_shader_explicit_arithmetic_types_int8 : require
#extension GL_EXT_float_e4m3 : require
#extension GL_EXT_spirv_intrinsics : require

spirv_instruction(
    extensions = ["SPV_VALVE_mixed_float_dot_product"],
    capabilities = [6915],
    id = 6918
)
float fp8_dot4_acc32(fe4m3vec4 a, fe4m3vec4 b, float accumulator);

layout(local_size_x = 64, local_size_y = 1, local_size_z = 1) in;

layout(set = 0, binding = 0) readonly buffer HiddenFrame { uint words[]; } hidden_frame;
layout(set = 0, binding = 1) readonly buffer ExpertRoutes { uint words[]; } expert_routes;
layout(set = 0, binding = 2) buffer ExpertIntermediates { uint words[]; } expert_intermediates;
layout(set = 0, binding = 3) readonly buffer ExpertInputWeight { uint words[]; } expert_input_weight;
layout(set = 0, binding = 4) readonly buffer ExpertInputScaleInv { uint words[]; } expert_input_scale_inv;

const uint BLOCK_ROWS = {{BLOCK_ROWS}}u;
const uint BLOCK_COLUMNS = {{BLOCK_COLUMNS}}u;
const uint HIDDEN_SIZE = {{HIDDEN_SIZE}}u;
const uint INTERMEDIATE_SIZE = {{INTERMEDIATE_SIZE}}u;
const uint NUM_EXPERTS = {{NUM_EXPERTS}}u;
const uint EXPERTS_PER_TOKEN = {{EXPERTS_PER_TOKEN}}u;
const uint TILE_ROWS = {{TILE_ROWS}}u;
const uint TILES_PER_ROUTE = (INTERMEDIATE_SIZE + TILE_ROWS - 1u) / TILE_ROWS;
const uint HIDDEN_FP8_WORDS = HIDDEN_SIZE / 4u;
const uint HIDDEN_BLOCKS = HIDDEN_SIZE / BLOCK_COLUMNS;
const uint BLOCK_FP8_WORDS = BLOCK_COLUMNS / 4u;
const uint INTERMEDIATE_WORDS = INTERMEDIATE_SIZE / 2u;
const uint EXPERT_INPUT_ROWS = INTERMEDIATE_SIZE * 2u;
const uint EXPERT_INPUT_WORDS = EXPERT_INPUT_ROWS * HIDDEN_SIZE / 4u;
const uint SCALE_ROWS = (EXPERT_INPUT_ROWS + BLOCK_ROWS - 1u) / BLOCK_ROWS;
const uint SCALE_COLUMNS = HIDDEN_BLOCKS;

// Pedal-private transient layer: one dynamic FP8 representation is shared by
// every output row in this matrix tile while lane-contiguous weight reads stay
// coalesced.
shared fe4m3vec4 quantized_hidden[HIDDEN_FP8_WORDS];
shared float hidden_scales[HIDDEN_BLOCKS];
shared float subgroup_gate[TILE_ROWS][64];
shared float subgroup_up[TILE_ROWS][64];
shared float activated_rows[TILE_ROWS];

float bf16_to_f32(uint value) { return uintBitsToFloat((value & 0xffffu) << 16); }

uint f32_to_bf16(float value) {
    uint bits = floatBitsToUint(value);
    uint lsb = (bits >> 16) & 1u;
    return (bits + 0x7fffu + lsb) >> 16;
}

float round_bf16(float value) { return bf16_to_f32(f32_to_bf16(value)); }

float read_bf16_word(uint packed, uint index) {
    return bf16_to_f32(packed >> ((index & 1u) * 16u));
}

vec4 read_hiddenx4(uint column) {
    uint offset = column >> 1u;
    uint lo = hidden_frame.words[offset];
    uint hi = hidden_frame.words[offset + 1u];
    return vec4(
        bf16_to_f32(lo),
        bf16_to_f32(lo >> 16u),
        bf16_to_f32(hi),
        bf16_to_f32(hi >> 16u)
    );
}

float read_scale(uint expert, uint row, uint block) {
    uint index = (expert * SCALE_ROWS + row / BLOCK_ROWS) * SCALE_COLUMNS + block;
    return read_bf16_word(expert_input_scale_inv.words[index >> 1u], index);
}

fe4m3vec4 read_weightx4(uint expert, uint row, uint column) {
    uint index = (expert * EXPERT_INPUT_ROWS + row) * HIDDEN_SIZE + column;
    uint packed = expert_input_weight.words[index >> 2u];
    return uintBitsToFloate4m3EXT(u8vec4(
        uint8_t(packed),
        uint8_t(packed >> 8u),
        uint8_t(packed >> 16u),
        uint8_t(packed >> 24u)
    ));
}

void main() {
    uint group = gl_WorkGroupID.x;
    uint route = group / TILES_PER_ROUTE;
    uint tile = group % TILES_PER_ROUTE;
    if (route >= EXPERTS_PER_TOKEN) {
        return;
    }
    uint expert = expert_routes.words[route] & 0xffffu;
    if (expert >= NUM_EXPERTS) {
        return;
    }
    uint expert_start = gl_WorkGroupID.z;
    uint expert_count = expert_input_weight.words.length() / EXPERT_INPUT_WORDS;
    if (expert < expert_start || expert >= expert_start + expert_count) {
        return;
    }
    expert -= expert_start;

    uint lane = gl_LocalInvocationID.x;
    uint cluster = lane >> 5u;
    uint cluster_lane = lane & 31u;
    for (uint block = cluster; block < HIDDEN_BLOCKS; block += 2u) {
        uint word = block * BLOCK_FP8_WORDS + cluster_lane;
        vec4 hidden = read_hiddenx4(word * 4u);
        float lane_max = max(
            max(abs(hidden.x), abs(hidden.y)),
            max(abs(hidden.z), abs(hidden.w))
        );
        float block_max = subgroupClusteredMax(lane_max, 32u);
        float scale = block_max > 0.0 ? block_max / 448.0 : 1.0;
        if (cluster_lane == 0u) {
            hidden_scales[block] = scale;
        }
        quantized_hidden[word] = fe4m3vec4(hidden / scale);
    }
    barrier();

    uint first_row = tile * TILE_ROWS;
    for (uint local_row = 0u; local_row < TILE_ROWS; local_row++) {
        uint row = first_row + local_row;
        float gate = 0.0;
        float up = 0.0;
        if (row < INTERMEDIATE_SIZE) {
            for (uint word = lane; word < HIDDEN_FP8_WORDS; word += 64u) {
                uint block = word / BLOCK_FP8_WORDS;
                uint column = word * 4u;
                float activation_scale = hidden_scales[block];
                fe4m3vec4 hidden = quantized_hidden[word];
                gate = fma(
                    fp8_dot4_acc32(hidden, read_weightx4(expert, row, column), 0.0),
                    activation_scale * read_scale(expert, row, block),
                    gate
                );
                up = fma(
                    fp8_dot4_acc32(
                        hidden,
                        read_weightx4(expert, INTERMEDIATE_SIZE + row, column),
                        0.0
                    ),
                    activation_scale
                        * read_scale(expert, INTERMEDIATE_SIZE + row, block),
                    up
                );
            }
        }
        gate = subgroupAdd(gate);
        up = subgroupAdd(up);
        if (gl_SubgroupInvocationID == 0u) {
            subgroup_gate[local_row][gl_SubgroupID] = gate;
            subgroup_up[local_row][gl_SubgroupID] = up;
        }
    }
    barrier();

    if (lane < TILE_ROWS) {
        uint row = first_row + lane;
        float gate = 0.0;
        float up = 0.0;
        for (uint subgroup = 0u; subgroup < gl_NumSubgroups; subgroup++) {
            gate += subgroup_gate[lane][subgroup];
            up += subgroup_up[lane][subgroup];
        }
        if (row < INTERMEDIATE_SIZE) {
            gate = round_bf16(gate);
            up = round_bf16(up);
            activated_rows[lane] = round_bf16(
                round_bf16(gate / (1.0 + exp(-gate))) * up
            );
        } else {
            activated_rows[lane] = 0.0;
        }
    }
    barrier();

    if (lane < TILE_ROWS / 2u) {
        uint row = first_row + lane * 2u;
        if (row < INTERMEDIATE_SIZE) {
            uint hi = row + 1u < INTERMEDIATE_SIZE
                ? f32_to_bf16(activated_rows[lane * 2u + 1u])
                : 0u;
            expert_intermediates.words[route * INTERMEDIATE_WORDS + row / 2u] =
                (hi << 16u) | f32_to_bf16(activated_rows[lane * 2u]);
        }
    }
}
