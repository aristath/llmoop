#version 450

#extension GL_KHR_shader_subgroup_basic : require
#extension GL_KHR_shader_subgroup_arithmetic : require
{{FP8_EXTENSIONS}}

layout(local_size_x = {{VALUE_HEAD_WIDTH}}, local_size_y = 1, local_size_z = 1) in;

layout(set = 0, binding = 0) readonly buffer QkvInput {
    uint words[];
} qkv_input;

layout(set = 0, binding = 1) readonly buffer ZInput {
    uint words[];
} z_input;

layout(set = 0, binding = 2) readonly buffer BInput {
    uint words[];
} b_input;

layout(set = 0, binding = 3) readonly buffer AInput {
    uint words[];
} a_input;

layout(set = 0, binding = 4) buffer OutputFrame {
    uint words[];
} output_frame;
{{PHYSICAL_OUTPUT_BINDINGS}}

layout(set = 0, binding = {{A_LOG_BINDING}}) readonly buffer ALog {
    uint words[];
} a_log;

layout(set = 0, binding = {{DT_BIAS_BINDING}}) readonly buffer DtBias {
    uint words[];
} dt_bias;

layout(set = 0, binding = {{NORM_WEIGHT_BINDING}}) readonly buffer NormWeight {
    uint words[];
} norm_weight;

layout(set = 0, binding = {{STATE_READ_BINDING}}) readonly buffer StateRead {
    float values[];
} state_read;

layout(set = 0, binding = {{STATE_WRITE_BINDING}}) buffer StateWrite {
    float values[];
} state_write;

const uint KEY_HEADS = {{KEY_HEADS}}u;
const uint KEY_HEAD_WIDTH = {{KEY_HEAD_WIDTH}}u;
const uint VALUE_HEADS = {{VALUE_HEADS}}u;
const uint VALUE_HEAD_WIDTH = {{VALUE_HEAD_WIDTH}}u;
const uint KEY_HEAD_REPEAT = {{KEY_HEAD_REPEAT}}u;
const uint KEY_WIDTH = KEY_HEADS * KEY_HEAD_WIDTH;
const uint VALUE_WIDTH = VALUE_HEADS * VALUE_HEAD_WIDTH;
const float NORM_EPS = {{NORM_EPS}};

shared float q_inv_norm;
shared float k_inv_norm;
shared float head_output[VALUE_HEAD_WIDTH];
shared float reduction[VALUE_HEAD_WIDTH];

float bf16_to_f32(uint value) {
    return uintBitsToFloat((value & 0xffffu) << 16);
}

uint f32_to_bf16(float value) {
    uint bits = floatBitsToUint(value);
    uint lsb = (bits >> 16) & 1u;
    uint rounding_bias = 0x7fffu + lsb;
    return (bits + rounding_bias) >> 16;
}

float unpack_bf16(uint packed, uint index) {
    return bf16_to_f32((index & 1u) == 0u ? packed : packed >> 16);
}


float read_qkv(uint index) {
    return unpack_bf16(qkv_input.words[index >> 1u], index);
}

float read_z(uint index) {
    return unpack_bf16(z_input.words[index >> 1u], index);
}

float read_b(uint index) {
    return unpack_bf16(b_input.words[index >> 1u], index);
}

float read_a(uint index) {
    return unpack_bf16(a_input.words[index >> 1u], index);
}

float read_a_log(uint index) {
    return {{READ_A_LOG}};
}

float read_dt_bias(uint index) {
    return {{READ_DT_BIAS}};
}

float read_norm_weight(uint index) {
    return {{READ_NORM_WEIGHT}};
}

float softplus(float value) {
    return value > 20.0 ? value : log(1.0 + exp(value));
}
{{FP8_HELPERS}}

void main() {
    uint value_head = gl_WorkGroupID.x;
    uint value_dim = gl_LocalInvocationID.x;
    if (value_head >= VALUE_HEADS) {
        return;
    }

    uint key_head = value_head / KEY_HEAD_REPEAT;
    uint q_base = key_head * KEY_HEAD_WIDTH;
    uint k_base = KEY_WIDTH + q_base;
    uint v_base = 2u * KEY_WIDTH + value_head * VALUE_HEAD_WIDTH;
    uint state_base = value_head * KEY_HEAD_WIDTH * VALUE_HEAD_WIDTH;

    if (value_dim == 0u) {
        float q_sum = 0.0;
        float k_sum = 0.0;
        for (uint key_dim = 0u; key_dim < KEY_HEAD_WIDTH; key_dim++) {
            float q = read_qkv(q_base + key_dim);
            float k = read_qkv(k_base + key_dim);
            q_sum = fma(q, q, q_sum);
            k_sum = fma(k, k, k_sum);
        }
        q_inv_norm = inversesqrt(q_sum + 0.000001);
        k_inv_norm = inversesqrt(k_sum + 0.000001);
    }
    barrier();

    float beta = 1.0 / (1.0 + exp(-read_b(value_head)));
    float decay_log = -exp(read_a_log(value_head)) * softplus(
        read_a(value_head)
        + read_dt_bias(value_head)
    );
    float decay = exp(decay_log);

    float key_memory = 0.0;
    for (uint key_dim = 0u; key_dim < KEY_HEAD_WIDTH; key_dim++) {
        uint state_index = state_base + key_dim * VALUE_HEAD_WIDTH + value_dim;
        float previous = state_read.values[state_index] * decay;
        float key = read_qkv(k_base + key_dim) * k_inv_norm;
        key_memory = fma(previous, key, key_memory);
    }
    float value = read_qkv(v_base + value_dim);
    float delta = (value - key_memory) * beta;

    float mixed = 0.0;
    float attention_scale = inversesqrt(float(KEY_HEAD_WIDTH));
    for (uint key_dim = 0u; key_dim < KEY_HEAD_WIDTH; key_dim++) {
        uint state_index = state_base + key_dim * VALUE_HEAD_WIDTH + value_dim;
        float key = read_qkv(k_base + key_dim) * k_inv_norm;
        float next = state_read.values[state_index] * decay + key * delta;
        state_write.values[state_index] = next;
        float query = read_qkv(q_base + key_dim) * q_inv_norm;
        mixed = fma(next, query * attention_scale, mixed);
    }

    float partial = subgroupAdd(mixed * mixed);
    if (gl_SubgroupInvocationID == 0u) {
        reduction[gl_SubgroupID] = partial;
    }
    barrier();
    float sum_squares = 0.0;
    for (uint subgroup = 0u; subgroup < gl_NumSubgroups; subgroup++) {
        sum_squares += reduction[subgroup];
    }
    float inv_rms = inversesqrt(sum_squares / float(VALUE_HEAD_WIDTH) + NORM_EPS);
    float z = read_z(value_head * VALUE_HEAD_WIDTH + value_dim);
    head_output[value_dim] = mixed * inv_rms * read_norm_weight(value_dim)
        * (z / (1.0 + exp(-z)));
    barrier();

{{OUTPUT_STORE}}
}
