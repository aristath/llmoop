#version 450

layout(local_size_x = 64, local_size_y = 1, local_size_z = 1) in;

layout(set = 0, binding = 0) readonly buffer TemporalWindow {
    uint words[];
} temporal_window;

layout(set = 0, binding = 1) buffer ConvOut {
    uint words[];
} conv_out;

layout(set = 0, binding = 2) readonly buffer ConvKernel {
    uint words[];
} conv_kernel;

layout(set = 0, binding = 3) readonly buffer TemporalWindowView {
    uint words[];
} temporal_window_view;

const uint HIDDEN_SIZE = 1024u;
const uint KERNEL_TAPS = 3u;
const uint OUTPUT_WORD_COUNT = 512u;

float bf16_to_f32(uint value) {
    return uintBitsToFloat((value & 0xffffu) << 16);
}

uint f32_to_bf16(float value) {
    uint bits = floatBitsToUint(value);
    uint lsb = (bits >> 16) & 1u;
    uint rounding_bias = 0x7fffu + lsb;
    return (bits + rounding_bias) >> 16;
}

uint bf16_at_temporal(uint element_index) {
    uint packed = temporal_window.words[element_index >> 1u];
    if ((element_index & 1u) == 0u) {
        return packed & 0xffffu;
    }
    return packed >> 16;
}

uint bf16_at_kernel(uint element_index) {
    uint packed = conv_kernel.words[element_index >> 1u];
    if ((element_index & 1u) == 0u) {
        return packed & 0xffffu;
    }
    return packed >> 16;
}

float depthwise_channel(uint channel) {
    float acc = 0.0;
    for (uint tap = 0u; tap < KERNEL_TAPS; tap = tap + 1u) {
        uint temporal_bf16 = bf16_at_temporal((tap * HIDDEN_SIZE) + channel);
        uint kernel_bf16 = bf16_at_kernel((channel * KERNEL_TAPS) + tap);
        acc = acc + (bf16_to_f32(temporal_bf16) * bf16_to_f32(kernel_bf16));
    }
    return acc;
}

void main() {
    for (uint word_index = gl_LocalInvocationID.x; word_index < OUTPUT_WORD_COUNT; word_index += 64u) {
        uint channel_lo = word_index * 2u;
        uint channel_hi = channel_lo + 1u;
        uint out_lo = f32_to_bf16(depthwise_channel(channel_lo));
        uint out_hi = f32_to_bf16(depthwise_channel(channel_hi));
        conv_out.words[word_index] = (out_hi << 16) | out_lo;
    }
}
