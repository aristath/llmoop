#version 450

layout(local_size_x = 64, local_size_y = 1, local_size_z = 1) in;

layout(set = 0, binding = 0) readonly buffer InputFrame {
    uint words[];
} input_frame;

layout(set = 0, binding = 1) buffer OutputA {
    uint words[];
} output_a;

layout(set = 0, binding = 2) buffer OutputB {
    uint words[];
} output_b;

const uint PART_WORDS = {{PART_WIDTH}}u / 2u;

void main() {
    for (uint word_index = gl_LocalInvocationID.x; word_index < PART_WORDS; word_index += 64u) {
        output_a.words[word_index] = input_frame.words[word_index];
        output_b.words[word_index] = input_frame.words[PART_WORDS + word_index];
    }
}
