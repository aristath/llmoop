#version 450

layout(local_size_x = 64, local_size_y = 1, local_size_z = 1) in;

layout(set = 0, binding = 0) readonly buffer InputFrame {
    uint words[];
} input_frame;

layout(set = 0, binding = 1) buffer OutputFrame {
    uint words[];
} output_frame;

const uint WORD_COUNT = 1280u;

float bf16_to_f32(uint value) {
    return uintBitsToFloat((value & 0xffffu) << 16);
}

uint f32_to_bf16(float value) {
    uint bits = floatBitsToUint(value);
    uint lsb = (bits >> 16) & 1u;
    uint rounding_bias = 0x7fffu + lsb;
    return (bits + rounding_bias) >> 16;
}

float silu(float value) {
    return value / (1.0 + exp(-value));
}

void main() {
    for (uint word_index = gl_LocalInvocationID.x; word_index < WORD_COUNT; word_index += 64u) {
        uint packed = input_frame.words[word_index];
        float lo = bf16_to_f32(packed & 0xffffu);
        float hi = bf16_to_f32(packed >> 16);
        output_frame.words[word_index] =
            (f32_to_bf16(silu(hi)) << 16) | f32_to_bf16(silu(lo));
    }
}
