#version 450

#extension GL_KHR_shader_subgroup_basic : require
#extension GL_KHR_shader_subgroup_arithmetic : require

layout(local_size_x = 64, local_size_y = 1, local_size_z = 1) in;

layout(set = 0, binding = 0) readonly buffer InputFrame {
    uint words[];
} input_frame;

layout(set = 0, binding = 1) buffer OutputFrame {
    uint words[];
} output_frame;

layout(set = 0, binding = 2) readonly buffer GateWeight {
    uint words[];
} gate_weight;

layout(set = 0, binding = 3) readonly buffer UpWeight {
    uint words[];
} up_weight;

const uint INPUT_SIZE = {{INPUT_SIZE}}u;
const uint INPUT_WORDS = INPUT_SIZE / 2u;
const uint OUTPUT_SIZE = {{OUTPUT_SIZE}}u;
const uint OUTPUT_WORDS = OUTPUT_SIZE / 2u;
const bool PAIRED_WEIGHT_LAYOUT = {{PAIRED_WEIGHT_LAYOUT}};

shared float subgroup_gate_lo[64];
shared float subgroup_gate_hi[64];
shared float subgroup_up_lo[64];
shared float subgroup_up_hi[64];

float bf16_to_f32(uint value) {
    return uintBitsToFloat((value & 0xffffu) << 16);
}

uint f32_to_bf16(float value) {
    uint bits = floatBitsToUint(value);
    uint lsb = (bits >> 16) & 1u;
    uint rounding_bias = 0x7fffu + lsb;
    return (bits + rounding_bias) >> 16;
}

uint weight_index(uint output_word, uint column_word, uint row_offset) {
    if (PAIRED_WEIGHT_LAYOUT) {
        return (2u * ((output_word * INPUT_WORDS) + column_word)) + row_offset;
    }
    uint row = (output_word * 2u) + row_offset;
    return (row * INPUT_WORDS) + column_word;
}

float round_bf16(float value) {
    return bf16_to_f32(f32_to_bf16(value));
}

float rounded_silu(float value) {
    return round_bf16(value / (1.0 + exp(-value)));
}

void write_result(
    uint output_word,
    float gate_lo,
    float gate_hi,
    float up_lo,
    float up_hi
) {
    float rounded_gate_lo = round_bf16(gate_lo);
    float rounded_gate_hi = round_bf16(gate_hi);
    float rounded_up_lo = round_bf16(up_lo);
    float rounded_up_hi = round_bf16(up_hi);
    uint lo = f32_to_bf16(rounded_silu(rounded_gate_lo) * rounded_up_lo);
    uint hi = f32_to_bf16(rounded_silu(rounded_gate_hi) * rounded_up_hi);
    output_frame.words[output_word] = (hi << 16) | lo;
}

void main() {
    uint output_word = gl_WorkGroupID.x;
    uint lane = gl_LocalInvocationID.x;
    if (output_word >= OUTPUT_WORDS) {
        return;
    }

    float gate_lo = 0.0;
    float gate_hi = 0.0;
    float up_lo = 0.0;
    float up_hi = 0.0;
    for (uint column_word = lane; column_word < INPUT_WORDS; column_word += 64u) {
        uint input_pair = input_frame.words[column_word];
        float input_lo = bf16_to_f32(input_pair);
        float input_hi = bf16_to_f32(input_pair >> 16);
        uint gate_lo_weight = gate_weight.words[
            weight_index(output_word, column_word, 0u)
        ];
        uint gate_hi_weight = gate_weight.words[
            weight_index(output_word, column_word, 1u)
        ];
        uint up_lo_weight = up_weight.words[
            weight_index(output_word, column_word, 0u)
        ];
        uint up_hi_weight = up_weight.words[
            weight_index(output_word, column_word, 1u)
        ];

        gate_lo = fma(input_lo, bf16_to_f32(gate_lo_weight), gate_lo);
        gate_lo = fma(input_hi, bf16_to_f32(gate_lo_weight >> 16), gate_lo);
        gate_hi = fma(input_lo, bf16_to_f32(gate_hi_weight), gate_hi);
        gate_hi = fma(input_hi, bf16_to_f32(gate_hi_weight >> 16), gate_hi);
        up_lo = fma(input_lo, bf16_to_f32(up_lo_weight), up_lo);
        up_lo = fma(input_hi, bf16_to_f32(up_lo_weight >> 16), up_lo);
        up_hi = fma(input_lo, bf16_to_f32(up_hi_weight), up_hi);
        up_hi = fma(input_hi, bf16_to_f32(up_hi_weight >> 16), up_hi);
    }

    gate_lo = subgroupAdd(gate_lo);
    gate_hi = subgroupAdd(gate_hi);
    up_lo = subgroupAdd(up_lo);
    up_hi = subgroupAdd(up_hi);
    if (gl_NumSubgroups == 1u) {
        if (gl_SubgroupInvocationID == 0u) {
            write_result(output_word, gate_lo, gate_hi, up_lo, up_hi);
        }
        return;
    }

    if (gl_SubgroupInvocationID == 0u) {
        subgroup_gate_lo[gl_SubgroupID] = gate_lo;
        subgroup_gate_hi[gl_SubgroupID] = gate_hi;
        subgroup_up_lo[gl_SubgroupID] = up_lo;
        subgroup_up_hi[gl_SubgroupID] = up_hi;
    }
    barrier();

    if (lane == 0u) {
        gate_lo = 0.0;
        gate_hi = 0.0;
        up_lo = 0.0;
        up_hi = 0.0;
        for (uint subgroup = 0u; subgroup < gl_NumSubgroups; subgroup++) {
            gate_lo += subgroup_gate_lo[subgroup];
            gate_hi += subgroup_gate_hi[subgroup];
            up_lo += subgroup_up_lo[subgroup];
            up_hi += subgroup_up_hi[subgroup];
        }
        write_result(output_word, gate_lo, gate_hi, up_lo, up_hi);
    }
}
