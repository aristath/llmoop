#version 460

#extension GL_KHR_shader_subgroup_basic : require
#extension GL_KHR_shader_subgroup_arithmetic : require

layout(local_size_x = 64, local_size_y = 1, local_size_z = 1) in;

layout(set = 0, binding = 0) readonly buffer ExpertIntermediates { uint words[]; } expert_intermediates;
layout(set = 0, binding = 1) readonly buffer ExpertRoutes { uint words[]; } expert_routes;
layout(set = 0, binding = 2) buffer ExpertOutputs { uint words[]; } expert_outputs;
layout(set = 0, binding = 3) readonly buffer ExpertOutputWeight { uint words[]; } expert_output_weight;
layout(set = 0, binding = 4) readonly buffer ExpertOutputScales { uint words[]; } expert_output_scales;

{{BATCH_CONTROL}}

const uint GROUP_SIZE = {{GROUP_SIZE}}u;
const uint HIDDEN_SIZE = {{HIDDEN_SIZE}}u;
const uint INTERMEDIATE_SIZE = {{INTERMEDIATE_SIZE}}u;
const uint NUM_EXPERTS = {{NUM_EXPERTS}}u;
const uint EXPERTS_PER_TOKEN = {{EXPERTS_PER_TOKEN}}u;
const uint TILE_ROWS = {{TILE_ROWS}}u;
const uint TILES_PER_ROUTE = (HIDDEN_SIZE + TILE_ROWS - 1u) / TILE_ROWS;
const uint HIDDEN_WORDS = HIDDEN_SIZE / 2u;
const uint INTERMEDIATE_WORDS = INTERMEDIATE_SIZE / 2u;
const uint PACKED_COLUMNS = INTERMEDIATE_SIZE / 8u;
const uint SCALE_COLUMNS = INTERMEDIATE_SIZE / GROUP_SIZE;
const uint EXPERT_OUTPUT_WORDS = HIDDEN_SIZE * PACKED_COLUMNS;

shared float subgroup_sum[TILE_ROWS][64];
shared float output_rows[TILE_ROWS];

float bf16_to_f32(uint value) {
    return uintBitsToFloat((value & 0xffffu) << 16u);
}

float read_bf16_word(uint packed, uint index) {
    return bf16_to_f32(packed >> ((index & 1u) * 16u));
}

uint f32_to_bf16(float value) {
    uint bits = floatBitsToUint(value);
    uint lsb = (bits >> 16u) & 1u;
    return (bits + 0x7fffu + lsb) >> 16u;
}

float round_bf16(float value) {
    return bf16_to_f32(f32_to_bf16(value));
}

vec4 read_intermediatex4(uint route_index, uint column) {
    uint offset = route_index * INTERMEDIATE_WORDS + (column >> 1u);
    uint lo = expert_intermediates.words[offset];
    uint hi = expert_intermediates.words[offset + 1u];
    return vec4(
        bf16_to_f32(lo),
        bf16_to_f32(lo >> 16u),
        bf16_to_f32(hi),
        bf16_to_f32(hi >> 16u)
    );
}

float read_scale(uint expert, uint row, uint group) {
    uint index = (expert * HIDDEN_SIZE + row) * SCALE_COLUMNS + group;
{{READ_SCALE_BODY}}
}

vec4 unpack_weight_lo(uint packed) {
    return vec4(
        float(int(packed & 15u) - 8),
        float(int((packed >> 4u) & 15u) - 8),
        float(int((packed >> 8u) & 15u) - 8),
        float(int((packed >> 12u) & 15u) - 8)
    );
}

vec4 unpack_weight_hi(uint packed) {
    return vec4(
        float(int((packed >> 16u) & 15u) - 8),
        float(int((packed >> 20u) & 15u) - 8),
        float(int((packed >> 24u) & 15u) - 8),
        float(int((packed >> 28u) & 15u) - 8)
    );
}

void main() {
    uint batch_index = {{BATCH_INDEX}};
    uint group = gl_WorkGroupID.x;
    uint route = group / TILES_PER_ROUTE;
    uint tile = group % TILES_PER_ROUTE;
    if (batch_index >= {{BATCH_WIDTH}} || route >= EXPERTS_PER_TOKEN) return;
    uint route_offset = batch_index * EXPERTS_PER_TOKEN;
    uint route_index = route_offset + route;
    uint packed_route = expert_routes.words[route_index];
    uint expert = packed_route & 0xffffu;
    if (expert >= NUM_EXPERTS) return;
    uint expert_start = {{EXPERT_START}};
    uint expert_count = expert_output_weight.words.length() / EXPERT_OUTPUT_WORDS;
    if (expert < expert_start || expert >= expert_start + expert_count) return;
    expert -= expert_start;
    float route_weight = bf16_to_f32(packed_route >> 16u);

    uint lane = gl_LocalInvocationID.x;
    uint first_row = tile * TILE_ROWS;
    for (uint local_row = 0u; local_row < TILE_ROWS; local_row++) {
        uint row = first_row + local_row;
        float sum = 0.0;
        if (row < HIDDEN_SIZE) {
            for (uint packed_column = lane; packed_column < PACKED_COLUMNS; packed_column += 64u) {
                uint packed = expert_output_weight.words[
                    (expert * HIDDEN_SIZE + row) * PACKED_COLUMNS + packed_column
                ];
                uint scale_group = packed_column * 8u / GROUP_SIZE;
                sum = fma(
                    dot(
                        read_intermediatex4(route_index, packed_column * 8u),
                        unpack_weight_lo(packed)
                    ) + dot(
                        read_intermediatex4(route_index, packed_column * 8u + 4u),
                        unpack_weight_hi(packed)
                    ),
                    read_scale(expert, row, scale_group),
                    sum
                );
            }
        }
        sum = subgroupAdd(sum);
        if (gl_SubgroupInvocationID == 0u) {
            subgroup_sum[local_row][gl_SubgroupID] = sum;
        }
    }
    barrier();

    if (lane < TILE_ROWS) {
        uint row = first_row + lane;
        float sum = 0.0;
        for (uint subgroup = 0u; subgroup < gl_NumSubgroups; subgroup++) {
            sum += subgroup_sum[lane][subgroup];
        }
        output_rows[lane] = row < HIDDEN_SIZE
            ? round_bf16(round_bf16(sum) * route_weight)
            : 0.0;
    }
    barrier();

    if (lane < TILE_ROWS / 2u) {
        uint row = first_row + lane * 2u;
        if (row < HIDDEN_SIZE) {
            uint hi = row + 1u < HIDDEN_SIZE
                ? f32_to_bf16(output_rows[lane * 2u + 1u])
                : 0u;
            expert_outputs.words[route_index * HIDDEN_WORDS + row / 2u] =
                (hi << 16u) | f32_to_bf16(output_rows[lane * 2u]);
        }
    }
}
