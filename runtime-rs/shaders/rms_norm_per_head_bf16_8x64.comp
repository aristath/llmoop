#version 450

#extension GL_KHR_shader_subgroup_basic : require
#extension GL_KHR_shader_subgroup_arithmetic : require

layout(local_size_x = 64, local_size_y = 1, local_size_z = 1) in;

layout(set = 0, binding = 0) readonly buffer InputFrame {
    uint words[];
} input_frame;

layout(set = 0, binding = 1) buffer OutputFrame {
    uint words[];
} output_frame;

layout(set = 0, binding = 2) readonly buffer Weight {
    uint words[];
} weight;

const uint HEAD_COUNT = 8u;
const uint HEAD_WIDTH = 64u;

shared float reduction[64];

float bf16_to_f32(uint value) {
    return uintBitsToFloat((value & 0xffffu) << 16);
}

uint f32_to_bf16(float value) {
    uint bits = floatBitsToUint(value);
    uint lsb = (bits >> 16) & 1u;
    uint rounding_bias = 0x7fffu + lsb;
    return (bits + rounding_bias) >> 16;
}

float read_input(uint index) {
    uint packed = input_frame.words[index >> 1];
    uint value = ((index & 1u) == 0u) ? (packed & 0xffffu) : (packed >> 16);
    return bf16_to_f32(value);
}

float read_weight(uint index) {
    uint packed = weight.words[index >> 1];
    uint value = ((index & 1u) == 0u) ? (packed & 0xffffu) : (packed >> 16);
    return bf16_to_f32(value);
}

void main() {
    uint head = gl_WorkGroupID.x;
    uint dim = gl_LocalInvocationID.x;
    if (head >= HEAD_COUNT) {
        return;
    }

    uint base = head * HEAD_WIDTH;
    float value = read_input(base + dim);
    float sum_squares = subgroupAdd(value * value);
    if (gl_NumSubgroups > 1u) {
        if (gl_SubgroupInvocationID == 0u) {
            reduction[gl_SubgroupID] = sum_squares;
        }
        barrier();
        sum_squares = 0.0;
        for (uint subgroup = 0u; subgroup < gl_NumSubgroups; subgroup++) {
            sum_squares += reduction[subgroup];
        }
    }
    float inv_rms = inversesqrt((sum_squares / float(HEAD_WIDTH)) + 0.00001);

    if (dim < (HEAD_WIDTH / 2u)) {
        uint pair_dim = dim * 2u;
        float lo = read_input(base + pair_dim) * inv_rms * read_weight(pair_dim);
        float hi = read_input(base + pair_dim + 1u) * inv_rms * read_weight(pair_dim + 1u);
        output_frame.words[(base + pair_dim) >> 1] =
                (f32_to_bf16(hi) << 16) | f32_to_bf16(lo);
    }
}
