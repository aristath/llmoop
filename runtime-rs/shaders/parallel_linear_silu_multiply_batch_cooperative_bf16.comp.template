#version 460

#extension GL_EXT_shader_16bit_storage : require
#extension GL_EXT_shader_explicit_arithmetic_types_int16 : require
#extension GL_EXT_bfloat16 : require
#extension GL_KHR_cooperative_matrix : require
#extension GL_KHR_memory_scope_semantics : require
#extension GL_KHR_shader_subgroup_basic : require

layout(local_size_x = 256, local_size_y = 1, local_size_z = 1) in;

layout(set = 0, binding = 0) readonly buffer InputFrames { bfloat16_t values[]; } input_frames;
layout(set = 0, binding = 1) buffer OutputFrames { uint16_t values[]; } output_frames;
layout(set = 0, binding = 2) readonly buffer GateWeight { bfloat16_t values[]; } gate_weight;
layout(set = 0, binding = 3) readonly buffer UpWeight { bfloat16_t values[]; } up_weight;

layout(push_constant) uniform BatchControl { uint batch_width; } batch_control;

const uint INPUT_SIZE = {{INPUT_SIZE}}u;
const uint OUTPUT_SIZE = {{OUTPUT_SIZE}}u;
const uint MATRIX_TILE = 16u;
const uint OUTPUT_TILE = 64u;
const uint BATCH_TILE = 64u;
const uint BATCH_SUBTILES = BATCH_TILE / MATRIX_TILE;
const uint BRANCH_COUNT = 2u;
const uint BRANCH_SUBGROUPS = 2u;
const uint OUTPUT_SUBTILES_PER_SUBGROUP =
    OUTPUT_TILE / (MATRIX_TILE * BRANCH_SUBGROUPS);

shared bfloat16_t weight_tile[BRANCH_COUNT * OUTPUT_TILE * MATRIX_TILE];
shared bfloat16_t input_tile[MATRIX_TILE * BATCH_TILE];
shared float result_tile[BRANCH_COUNT * OUTPUT_TILE * BATCH_TILE];

uint weight_index(uint row, uint column) {
    return row * INPUT_SIZE + column;
}

uint f32_to_bf16(float value) {
    uint bits = floatBitsToUint(value);
    uint lsb = (bits >> 16u) & 1u;
    return (bits + 0x7fffu + lsb) >> 16u;
}

float bf16_to_f32(uint16_t value) {
    return uintBitsToFloat(uint(value) << 16u);
}

float rounded_bf16(float value) {
    return bf16_to_f32(uint16_t(f32_to_bf16(value)));
}

void main() {
    uint output_start = gl_WorkGroupID.x * OUTPUT_TILE;
    uint batch_start = gl_WorkGroupID.y * BATCH_TILE;
    uint lane = gl_LocalInvocationID.x;
    uint branch = gl_SubgroupID / BRANCH_SUBGROUPS;
    uint subgroup_output_start =
        (gl_SubgroupID % BRANCH_SUBGROUPS) * OUTPUT_SUBTILES_PER_SUBGROUP;

    coopmat<float, gl_ScopeSubgroup, 16, 16, gl_MatrixUseAccumulator>
        sums[OUTPUT_SUBTILES_PER_SUBGROUP * BATCH_SUBTILES];
    for (uint index = 0u;
        index < OUTPUT_SUBTILES_PER_SUBGROUP * BATCH_SUBTILES;
        index++) {
        sums[index] = coopmat<float, gl_ScopeSubgroup, 16, 16,
            gl_MatrixUseAccumulator>(0.0);
    }

    for (uint input_start = 0u; input_start < INPUT_SIZE; input_start += MATRIX_TILE) {
        bool stage_weight = output_start + OUTPUT_TILE > OUTPUT_SIZE
            || input_start + MATRIX_TILE > INPUT_SIZE;
        if (stage_weight) {
            for (uint index = lane; index < BRANCH_COUNT * OUTPUT_TILE * MATRIX_TILE; index += 256u) {
                uint combined_row = index / MATRIX_TILE;
                uint weight_branch = combined_row / OUTPUT_TILE;
                uint row = combined_row % OUTPUT_TILE;
                uint column = index % MATRIX_TILE;
                uint output_index = output_start + row;
                uint input_index = input_start + column;
                weight_tile[index] = output_index < OUTPUT_SIZE && input_index < INPUT_SIZE
                    ? (weight_branch == 0u
                        ? gate_weight.values[weight_index(output_index, input_index)]
                        : up_weight.values[weight_index(output_index, input_index)])
                    : bfloat16_t(0.0);
            }
        }
        for (uint index = lane; index < MATRIX_TILE * BATCH_TILE; index += 256u) {
            uint input_row = index / BATCH_TILE;
            uint batch_lane = index % BATCH_TILE;
            uint batch_index = batch_start + batch_lane;
            uint input_column = input_start + input_row;
            input_tile[index] = batch_index < batch_control.batch_width
                && input_column < INPUT_SIZE
                ? input_frames.values[batch_index * INPUT_SIZE + input_column]
                : bfloat16_t(0.0);
        }
        barrier();

        for (uint local_output_subtile = 0u;
            local_output_subtile < OUTPUT_SUBTILES_PER_SUBGROUP;
            local_output_subtile++) {
            uint output_subtile = subgroup_output_start + local_output_subtile;
            coopmat<bfloat16_t, gl_ScopeSubgroup, 16, 16, gl_MatrixUseA> a;
            if (stage_weight) {
                coopMatLoad(
                    a,
                    weight_tile,
                    (branch * OUTPUT_TILE / MATRIX_TILE + output_subtile)
                        * MATRIX_TILE * MATRIX_TILE,
                    MATRIX_TILE,
                    gl_CooperativeMatrixLayoutRowMajor
                );
            } else if (branch == 0u) {
                coopMatLoad(
                    a,
                    gate_weight.values,
                    (output_start + output_subtile * MATRIX_TILE) * INPUT_SIZE
                        + input_start,
                    INPUT_SIZE,
                    gl_CooperativeMatrixLayoutRowMajor
                );
            } else {
                coopMatLoad(
                    a,
                    up_weight.values,
                    (output_start + output_subtile * MATRIX_TILE) * INPUT_SIZE
                        + input_start,
                    INPUT_SIZE,
                    gl_CooperativeMatrixLayoutRowMajor
                );
            }
            for (uint batch_subtile = 0u; batch_subtile < BATCH_SUBTILES; batch_subtile++) {
                uint sum_index = local_output_subtile * BATCH_SUBTILES + batch_subtile;
                coopmat<bfloat16_t, gl_ScopeSubgroup, 16, 16, gl_MatrixUseB> b;
                coopMatLoad(
                    b,
                    input_tile,
                    batch_subtile * MATRIX_TILE,
                    BATCH_TILE,
                    gl_CooperativeMatrixLayoutRowMajor
                );
                sums[sum_index] = coopMatMulAdd(a, b, sums[sum_index]);
            }
        }
        barrier();
    }

    for (uint local_output_subtile = 0u;
        local_output_subtile < OUTPUT_SUBTILES_PER_SUBGROUP;
        local_output_subtile++) {
        uint output_subtile = subgroup_output_start + local_output_subtile;
        for (uint batch_subtile = 0u; batch_subtile < BATCH_SUBTILES; batch_subtile++) {
            uint sum_index = local_output_subtile * BATCH_SUBTILES + batch_subtile;
            coopMatStore(
                sums[sum_index],
                result_tile,
                branch * OUTPUT_TILE * BATCH_TILE
                    + output_subtile * MATRIX_TILE * BATCH_TILE
                    + batch_subtile * MATRIX_TILE,
                BATCH_TILE,
                gl_CooperativeMatrixLayoutRowMajor
            );
        }
    }
    barrier();
    for (uint index = lane; index < OUTPUT_TILE * BATCH_TILE; index += 256u) {
        uint row = index / BATCH_TILE;
        uint batch_lane = index % BATCH_TILE;
        uint output_index = output_start + row;
        uint batch_index = batch_start + batch_lane;
        if (output_index < OUTPUT_SIZE && batch_index < batch_control.batch_width) {
            float gate = rounded_bf16(result_tile[index]);
            float up = rounded_bf16(result_tile[OUTPUT_TILE * BATCH_TILE + index]);
            float silu = rounded_bf16(gate / (1.0 + exp(-gate)));
            output_frames.values[batch_index * OUTPUT_SIZE + output_index] =
                uint16_t(f32_to_bf16(silu * up));
        }
    }
}
