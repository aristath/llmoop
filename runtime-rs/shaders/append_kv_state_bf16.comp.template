#version 450

layout(local_size_x = 64, local_size_y = 1, local_size_z = 1) in;

layout(set = 0, binding = 0) readonly buffer KInput {
    uint words[];
} k_input;

layout(set = 0, binding = 1) readonly buffer VInput {
    uint words[];
} v_input;

layout(set = 0, binding = 6) buffer KvStateWrite {
    uint words[];
} kv_state_write;

layout(set = 0, binding = 9) readonly buffer StreamControl {
    uint words[];
} stream_control;

const uint KV_HEADS = {{KV_HEADS}}u;
const uint HEAD_WIDTH = {{HEAD_WIDTH}}u;
const uint KV_ELEMENT_COUNT = KV_HEADS * HEAD_WIDTH;
const uint KV_WORD_COUNT = KV_ELEMENT_COUNT / 2u;
const uint SLOT_WORD_COUNT = KV_WORD_COUNT * 2u;

void main() {
    uint capacity = stream_control.words[4];
    if (capacity == 0u) {
        return;
    }

    uint slot = stream_control.words[1] % capacity;
    uint slot_base = slot * SLOT_WORD_COUNT;
    uint v_base = slot_base + KV_WORD_COUNT;

    for (uint word_index = gl_LocalInvocationID.x; word_index < KV_WORD_COUNT; word_index += 64u) {
        kv_state_write.words[slot_base + word_index] = k_input.words[word_index];
        kv_state_write.words[v_base + word_index] = v_input.words[word_index];
    }
}
