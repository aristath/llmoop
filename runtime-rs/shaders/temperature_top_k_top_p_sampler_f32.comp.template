#version 450

layout(local_size_x = {{LOCAL_SIZE_X}}, local_size_y = 1, local_size_z = 1) in;

layout(set = 0, binding = 0) readonly buffer Logits {
    float values[];
} logits;

layout(set = 0, binding = 1) buffer SamplerOutput {
    uint words[];
} sampler_output;

layout(set = 0, binding = 2) buffer StreamControl {
    uint words[];
} stream_control;

layout(set = 0, binding = 3) readonly buffer SamplerSeed {
    uint words[];
} sampler_seed;

const uint VOCAB_SIZE = {{VOCAB_SIZE}}u;
const uint TOP_K = {{TOP_K}}u;
const uint LOCAL_SIZE_X = {{LOCAL_SIZE_X}}u;
const uint LANE_CANDIDATE_COUNT = TOP_K * LOCAL_SIZE_X;
const float TEMPERATURE = {{TEMPERATURE}};
const float TOP_P = {{TOP_P}};
const float LOWEST_FLOAT = -3.4028234663852886e38;

shared float lane_top_logits[{{LOCAL_SIZE_X}} * {{TOP_K}}];
shared uint lane_top_token_ids[{{LOCAL_SIZE_X}} * {{TOP_K}}];
shared float final_top_logits[{{TOP_K}}];
shared uint final_top_token_ids[{{TOP_K}}];

bool candidate_is_better(
    float candidate_logit,
    uint candidate_token_id,
    float current_logit,
    uint current_token_id
) {
    return candidate_logit > current_logit
        || (candidate_logit == current_logit && candidate_token_id < current_token_id);
}

bool candidate_is_worse(
    float candidate_logit,
    uint candidate_token_id,
    float current_logit,
    uint current_token_id
) {
    return candidate_logit < current_logit
        || (candidate_logit == current_logit && candidate_token_id > current_token_id);
}

uint hash_u32(uint value) {
    value ^= value >> 16u;
    value *= 0x7feb352du;
    value ^= value >> 15u;
    value *= 0x846ca68bu;
    value ^= value >> 16u;
    return value;
}

float random_unit(uint stream_tick_low, uint stream_tick_high) {
    uint bits = hash_u32(
        sampler_seed.words[0]
        ^ stream_tick_low
        ^ (stream_tick_high * 0x9e3779b9u)
    );
    return float(bits >> 8u) * (1.0 / 16777216.0);
}

void main() {
    uint lane = gl_LocalInvocationID.x;
    uint base = lane * TOP_K;
    float local_top_logits[{{TOP_K}}];
    uint local_top_token_ids[{{TOP_K}}];
    for (uint index = 0u; index < TOP_K; index += 1u) {
        local_top_logits[index] = LOWEST_FLOAT;
        local_top_token_ids[index] = 0xffffffffu;
    }

    // Keep each lane's candidates as an unsorted reservoir. The previous
    // insertion-sorted implementation compared almost every vocabulary logit
    // with all TOP_K entries. Once this reservoir is full, the common case is
    // one comparison against its worst entry; only a new top-k candidate needs
    // the short scan that locates the next worst entry.
    uint lane_worst_index = 0u;
    float lane_worst_logit = LOWEST_FLOAT;
    uint lane_worst_token_id = 0xffffffffu;
    for (uint token_id = lane; token_id < VOCAB_SIZE; token_id += LOCAL_SIZE_X) {
        float candidate_logit = logits.values[token_id];
        if (isnan(candidate_logit) || !candidate_is_better(
            candidate_logit,
            token_id,
            lane_worst_logit,
            lane_worst_token_id
        )) {
            continue;
        }

        local_top_logits[lane_worst_index] = candidate_logit;
        local_top_token_ids[lane_worst_index] = token_id;
        lane_worst_index = 0u;
        lane_worst_logit = local_top_logits[0];
        lane_worst_token_id = local_top_token_ids[0];
        for (uint index = 1u; index < TOP_K; index += 1u) {
            float stored_logit = local_top_logits[index];
            uint stored_token_id = local_top_token_ids[index];
            if (candidate_is_worse(
                stored_logit,
                stored_token_id,
                lane_worst_logit,
                lane_worst_token_id
            )) {
                lane_worst_index = index;
                lane_worst_logit = stored_logit;
                lane_worst_token_id = stored_token_id;
            }
        }
    }
    for (uint index = 0u; index < TOP_K; index += 1u) {
        lane_top_logits[base + index] = local_top_logits[index];
        lane_top_token_ids[base + index] = local_top_token_ids[index];
    }
    barrier();

    if (lane != 0u) {
        return;
    }

    for (uint index = 0u; index < TOP_K; index += 1u) {
        final_top_logits[index] = LOWEST_FLOAT;
        final_top_token_ids[index] = 0xffffffffu;
    }

    uint final_worst_index = 0u;
    float final_worst_logit = LOWEST_FLOAT;
    uint final_worst_token_id = 0xffffffffu;
    for (uint index = 0u; index < LANE_CANDIDATE_COUNT; index += 1u) {
        float candidate_logit = lane_top_logits[index];
        uint candidate_token_id = lane_top_token_ids[index];
        if (!candidate_is_better(
            candidate_logit,
            candidate_token_id,
            final_worst_logit,
            final_worst_token_id
        )) {
            continue;
        }

        final_top_logits[final_worst_index] = candidate_logit;
        final_top_token_ids[final_worst_index] = candidate_token_id;
        final_worst_index = 0u;
        final_worst_logit = final_top_logits[0];
        final_worst_token_id = final_top_token_ids[0];
        for (uint candidate_index = 1u; candidate_index < TOP_K; candidate_index += 1u) {
            float stored_logit = final_top_logits[candidate_index];
            uint stored_token_id = final_top_token_ids[candidate_index];
            if (candidate_is_worse(
                stored_logit,
                stored_token_id,
                final_worst_logit,
                final_worst_token_id
            )) {
                final_worst_index = candidate_index;
                final_worst_logit = stored_logit;
                final_worst_token_id = stored_token_id;
            }
        }
    }

    // Only the final TOP_K reservoir needs ordering for top-p truncation and
    // cumulative sampling. This is tiny compared with sorting every lane's
    // vocabulary partition while it is being scanned.
    for (uint position = 0u; position < TOP_K; position += 1u) {
        uint best_index = position;
        for (uint candidate_index = position + 1u; candidate_index < TOP_K; candidate_index += 1u) {
            if (candidate_is_better(
                final_top_logits[candidate_index],
                final_top_token_ids[candidate_index],
                final_top_logits[best_index],
                final_top_token_ids[best_index]
            )) {
                best_index = candidate_index;
            }
        }
        if (best_index != position) {
            float swap_logit = final_top_logits[position];
            uint swap_token_id = final_top_token_ids[position];
            final_top_logits[position] = final_top_logits[best_index];
            final_top_token_ids[position] = final_top_token_ids[best_index];
            final_top_logits[best_index] = swap_logit;
            final_top_token_ids[best_index] = swap_token_id;
        }
    }

    float maximum_scaled_logit = final_top_logits[0] / TEMPERATURE;
    float total_weight = 0.0;
    for (uint index = 0u; index < TOP_K; index += 1u) {
        total_weight += exp(final_top_logits[index] / TEMPERATURE - maximum_scaled_logit);
    }

    float nucleus_threshold = TOP_P * total_weight;
    float nucleus_weight = 0.0;
    uint nucleus_count = 0u;
    for (uint index = 0u; index < TOP_K; index += 1u) {
        nucleus_weight += exp(final_top_logits[index] / TEMPERATURE - maximum_scaled_logit);
        nucleus_count = index + 1u;
        if (nucleus_weight >= nucleus_threshold) {
            break;
        }
    }

    uint stream_tick_low = stream_control.words[1];
    uint stream_tick_high = stream_control.words[2];
    float target = random_unit(stream_tick_low, stream_tick_high) * nucleus_weight;
    float cumulative_weight = 0.0;
    uint selected_index = nucleus_count - 1u;
    for (uint index = 0u; index < nucleus_count; index += 1u) {
        cumulative_weight += exp(final_top_logits[index] / TEMPERATURE - maximum_scaled_logit);
        if (target < cumulative_weight) {
            selected_index = index;
            break;
        }
    }

    uint token_id = final_top_token_ids[selected_index];
    uint logit_bits = floatBitsToUint(final_top_logits[selected_index]);
    uint history_capacity = stream_control.words[4];
    uint history_word = 4u + (stream_tick_low % history_capacity) * 4u;

    sampler_output.words[0] = token_id;
    sampler_output.words[1] = logit_bits;
    sampler_output.words[2] = 1u;
    sampler_output.words[3] = 0u;
    sampler_output.words[history_word] = token_id;
    sampler_output.words[history_word + 1u] = logit_bits;
    sampler_output.words[history_word + 2u] = 1u;
    sampler_output.words[history_word + 3u] = 0u;

    stream_control.words[0] = token_id;
    uint next_tick_low = stream_tick_low + 1u;
    if (next_tick_low == 0u) {
        stream_control.words[2] += 1u;
    }
    stream_control.words[1] = next_tick_low;
}
