#version 460

#extension GL_EXT_shader_16bit_storage : require
#extension GL_EXT_shader_explicit_arithmetic_types_int16 : require
#extension GL_EXT_bfloat16 : require
#extension GL_EXT_spirv_intrinsics : require
#extension GL_KHR_shader_subgroup_basic : require
#extension GL_KHR_shader_subgroup_arithmetic : require

spirv_instruction(
    extensions = ["SPV_VALVE_mixed_float_dot_product"],
    capabilities = [6914],
    id = 6916
)
float bf16_dot2_acc32(bf16vec2 a, bf16vec2 b, float accumulator);

layout(local_size_x = 64, local_size_y = 1, local_size_z = 1) in;

layout(set = 0, binding = 0) readonly buffer NormalizedFrames {
    bf16vec2 values[];
} normalized_frames;
layout(set = 0, binding = 1) readonly buffer EmbeddingWeight {
    bf16vec2 values[];
} embedding_weight;
layout(set = 0, binding = 2) buffer BatchedLogits {
    float values[];
} batched_logits;

layout(push_constant) uniform BatchControl {
    uint batch_width;
} batch_control;

const uint BATCH_TILE_WIDTH = {{BATCH_TILE_WIDTH}}u;
const uint INPUT_SIZE = {{INPUT_SIZE}}u;
const uint VOCAB_SIZE = {{VOCAB_SIZE}}u;
const uint INPUT_PAIRS = INPUT_SIZE / 2u;
const uint OUTPUT_PAIRS = (VOCAB_SIZE + 1u) / 2u;
const float OUTPUT_SCALE = {{OUTPUT_SCALE}};

shared float subgroup_lo[BATCH_TILE_WIDTH][64];
shared float subgroup_hi[BATCH_TILE_WIDTH][64];

void store_result(
    uint batch_index,
    uint lo_row,
    uint hi_row,
    float lo_sum,
    float hi_sum
) {
    uint output_offset = batch_index * VOCAB_SIZE;
    batched_logits.values[output_offset + lo_row] = lo_sum * OUTPUT_SCALE;
    if (hi_row < VOCAB_SIZE) {
        batched_logits.values[output_offset + hi_row] = hi_sum * OUTPUT_SCALE;
    }
}

void main() {
    uint output_pair = gl_WorkGroupID.x;
    uint batch_start = gl_WorkGroupID.y * BATCH_TILE_WIDTH;
    uint lane = gl_LocalInvocationID.x;
    uint lo_row = output_pair * 2u;
    uint hi_row = lo_row + 1u;
    uint lo_weight_offset = lo_row * INPUT_PAIRS;
    uint hi_weight_offset = hi_row * INPUT_PAIRS;

    float lo_sum[BATCH_TILE_WIDTH];
    float hi_sum[BATCH_TILE_WIDTH];
    for (uint batch_lane = 0u; batch_lane < BATCH_TILE_WIDTH; batch_lane++) {
        lo_sum[batch_lane] = 0.0;
        hi_sum[batch_lane] = 0.0;
    }
    if (output_pair < OUTPUT_PAIRS) {
        for (
            uint column_pair = lane;
            column_pair < INPUT_PAIRS;
            column_pair += gl_WorkGroupSize.x
        ) {
            bf16vec2 lo_weight =
                embedding_weight.values[lo_weight_offset + column_pair];
            bf16vec2 hi_weight = hi_row < VOCAB_SIZE
                ? embedding_weight.values[hi_weight_offset + column_pair]
                : bf16vec2(0.0);
            for (uint batch_lane = 0u; batch_lane < BATCH_TILE_WIDTH; batch_lane++) {
                uint batch_index = batch_start + batch_lane;
                if (batch_index >= batch_control.batch_width) {
                    continue;
                }
                bf16vec2 input_pair = normalized_frames.values[
                    batch_index * INPUT_PAIRS + column_pair
                ];
                lo_sum[batch_lane] = bf16_dot2_acc32(
                    input_pair,
                    lo_weight,
                    lo_sum[batch_lane]
                );
                hi_sum[batch_lane] = bf16_dot2_acc32(
                    input_pair,
                    hi_weight,
                    hi_sum[batch_lane]
                );
            }
        }
    }

    for (uint batch_lane = 0u; batch_lane < BATCH_TILE_WIDTH; batch_lane++) {
        lo_sum[batch_lane] = subgroupAdd(lo_sum[batch_lane]);
        hi_sum[batch_lane] = subgroupAdd(hi_sum[batch_lane]);
    }
    if (gl_NumSubgroups == 1u) {
        if (gl_SubgroupInvocationID == 0u && output_pair < OUTPUT_PAIRS) {
            for (uint batch_lane = 0u; batch_lane < BATCH_TILE_WIDTH; batch_lane++) {
                uint batch_index = batch_start + batch_lane;
                if (batch_index < batch_control.batch_width) {
                    store_result(
                        batch_index,
                        lo_row,
                        hi_row,
                        lo_sum[batch_lane],
                        hi_sum[batch_lane]
                    );
                }
            }
        }
        return;
    }
    if (gl_SubgroupInvocationID == 0u) {
        for (uint batch_lane = 0u; batch_lane < BATCH_TILE_WIDTH; batch_lane++) {
            subgroup_lo[batch_lane][gl_SubgroupID] = lo_sum[batch_lane];
            subgroup_hi[batch_lane][gl_SubgroupID] = hi_sum[batch_lane];
        }
    }
    barrier();
    if (lane == 0u && output_pair < OUTPUT_PAIRS) {
        for (uint batch_lane = 0u; batch_lane < BATCH_TILE_WIDTH; batch_lane++) {
            uint batch_index = batch_start + batch_lane;
            if (batch_index >= batch_control.batch_width) {
                continue;
            }
            float lo_total = 0.0;
            float hi_total = 0.0;
            for (uint subgroup = 0u; subgroup < gl_NumSubgroups; subgroup++) {
                lo_total += subgroup_lo[batch_lane][subgroup];
                hi_total += subgroup_hi[batch_lane][subgroup];
            }
            store_result(batch_index, lo_row, hi_row, lo_total, hi_total);
        }
    }
}
