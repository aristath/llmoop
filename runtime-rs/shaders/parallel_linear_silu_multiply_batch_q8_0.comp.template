#version 460

#extension GL_KHR_shader_subgroup_basic : require
#extension GL_KHR_shader_subgroup_arithmetic : require
#extension GL_KHR_shader_subgroup_clustered : require
#extension GL_KHR_shader_subgroup_shuffle : require
#extension GL_EXT_integer_dot_product : require
#extension GL_EXT_shader_explicit_arithmetic_types_int32 : require

layout(local_size_x = 64, local_size_y = 1, local_size_z = 1) in;

layout(set = 0, binding = 0) readonly buffer InputFrames { uint words[]; } input_frames;
layout(set = 0, binding = 1) buffer OutputFrames { uint words[]; } output_frames;
layout(set = 0, binding = 2) readonly buffer GateWeight { uint words[]; } gate_weight;
layout(set = 0, binding = 3) readonly buffer UpWeight { uint words[]; } up_weight;

layout(push_constant) uniform BatchControl { uint batch_width; } batch_control;

const uint BATCH_TILE_WIDTH = {{BATCH_TILE_WIDTH}}u;
const uint INPUT_SIZE = {{INPUT_SIZE}}u;
const uint OUTPUT_SIZE = {{OUTPUT_SIZE}}u;
const uint OUTPUT_TILE_ROWS = {{OUTPUT_TILE_ROWS}}u;
const uint INPUT_WORDS = INPUT_SIZE / 2u;
const uint OUTPUT_WORDS = OUTPUT_SIZE / 2u;
const uint INPUT_BLOCKS = INPUT_SIZE / 32u;
const uint INPUT_Q8_WORDS = INPUT_SIZE / 4u;
const uint Q8_BLOCK_WORDS = 9u;

shared uint quantized_input[INPUT_Q8_WORDS];
shared float input_scales[INPUT_BLOCKS];
shared float gate_subgroup_sum[OUTPUT_TILE_ROWS][64];
shared float up_subgroup_sum[OUTPUT_TILE_ROWS][64];
shared float activated_rows[OUTPUT_TILE_ROWS];

float bf16_to_f32(uint value) { return uintBitsToFloat((value & 0xffffu) << 16u); }

uint f32_to_bf16(float value) {
    uint bits = floatBitsToUint(value);
    uint lsb = (bits >> 16u) & 1u;
    return (bits + 0x7fffu + lsb) >> 16u;
}

float round_bf16(float value) { return bf16_to_f32(f32_to_bf16(value)); }

float rounded_silu(float value) {
    return round_bf16(value / (1.0 + exp(-value)));
}

float read_bf16_word(uint packed, uint index) {
    return bf16_to_f32(packed >> ((index & 1u) * 16u));
}

float read_input(uint batch_index, uint column) {
    return read_bf16_word(
        input_frames.words[batch_index * INPUT_WORDS + (column >> 1u)],
        column
    );
}

int clamp_i8(float value) { return clamp(int(round(value)), -127, 127); }

uint pack_i8x4(int a, int b, int c, int d) {
    return (uint(a) & 255u)
        | ((uint(b) & 255u) << 8u)
        | ((uint(c) & 255u) << 16u)
        | ((uint(d) & 255u) << 24u);
}

float read_gate_scale(uint row, uint block) {
    uint index = (row * INPUT_BLOCKS + block) * Q8_BLOCK_WORDS;
    return bf16_to_f32(gate_weight.words[index]);
}

float read_up_scale(uint row, uint block) {
    uint index = (row * INPUT_BLOCKS + block) * Q8_BLOCK_WORDS;
    return bf16_to_f32(up_weight.words[index]);
}

uint read_gate_q8_word(uint row, uint q8_word) {
    uint block = q8_word >> 3u;
    uint word = q8_word & 7u;
    return gate_weight.words[(row * INPUT_BLOCKS + block) * Q8_BLOCK_WORDS + 1u + word];
}

uint read_up_q8_word(uint row, uint q8_word) {
    uint block = q8_word >> 3u;
    uint word = q8_word & 7u;
    return up_weight.words[(row * INPUT_BLOCKS + block) * Q8_BLOCK_WORDS + 1u + word];
}

void quantize_input(uint batch_index, uint lane) {
    uint cluster = lane >> 5u;
    uint cluster_lane = lane & 31u;
    for (uint block = cluster; block < INPUT_BLOCKS; block += 2u) {
        float value = read_input(batch_index, block * 32u + cluster_lane);
        float block_max = subgroupClusteredMax(abs(value), 32u);
        float scale = block_max > 0.0 ? block_max / 127.0 : 1.0;
        if (cluster_lane == 0u) {
            input_scales[block] = scale;
        }
        int quantized = clamp_i8(value / scale);
        if ((cluster_lane & 3u) == 0u) {
            quantized_input[block * 8u + (cluster_lane >> 2u)] = pack_i8x4(
                quantized,
                subgroupShuffle(quantized, gl_SubgroupInvocationID + 1u),
                subgroupShuffle(quantized, gl_SubgroupInvocationID + 2u),
                subgroupShuffle(quantized, gl_SubgroupInvocationID + 3u)
            );
        }
    }
}

void main() {
    uint lane = gl_LocalInvocationID.x;
    uint first_row = gl_WorkGroupID.x * OUTPUT_TILE_ROWS;
    uint batch_start = gl_WorkGroupID.y * BATCH_TILE_WIDTH;
    for (uint batch_lane = 0u; batch_lane < BATCH_TILE_WIDTH; batch_lane++) {
        uint batch_index = batch_start + batch_lane;
        if (batch_index >= batch_control.batch_width) {
            break;
        }
        quantize_input(batch_index, lane);
        barrier();

        for (uint local_row = 0u; local_row < OUTPUT_TILE_ROWS; local_row++) {
            uint row = first_row + local_row;
            float gate = 0.0;
            float up = 0.0;
            if (row < OUTPUT_SIZE) {
                for (uint q8_word = lane; q8_word < INPUT_Q8_WORDS; q8_word += 64u) {
                    uint block = q8_word >> 3u;
                    uint activation = quantized_input[q8_word];
                    int gate_dot = dotPacked4x8EXT(
                        int32_t(activation),
                        int32_t(read_gate_q8_word(row, q8_word))
                    );
                    int up_dot = dotPacked4x8EXT(
                        int32_t(activation),
                        int32_t(read_up_q8_word(row, q8_word))
                    );
                    float activation_scale = input_scales[block];
                    gate = fma(
                        float(gate_dot),
                        activation_scale * read_gate_scale(row, block),
                        gate
                    );
                    up = fma(
                        float(up_dot),
                        activation_scale * read_up_scale(row, block),
                        up
                    );
                }
            }
            gate = subgroupAdd(gate);
            up = subgroupAdd(up);
            if (gl_SubgroupInvocationID == 0u) {
                gate_subgroup_sum[local_row][gl_SubgroupID] = gate;
                up_subgroup_sum[local_row][gl_SubgroupID] = up;
            }
        }
        barrier();

        if (lane < OUTPUT_TILE_ROWS) {
            uint row = first_row + lane;
            float gate = 0.0;
            float up = 0.0;
            if (row < OUTPUT_SIZE) {
                for (uint subgroup = 0u; subgroup < gl_NumSubgroups; subgroup++) {
                    gate += gate_subgroup_sum[lane][subgroup];
                    up += up_subgroup_sum[lane][subgroup];
                }
            }
            activated_rows[lane] = rounded_silu(round_bf16(gate)) * round_bf16(up);
        }
        barrier();

        if (lane < OUTPUT_TILE_ROWS / 2u) {
            uint row = first_row + lane * 2u;
            if (row < OUTPUT_SIZE) {
                uint lo = f32_to_bf16(activated_rows[lane * 2u]);
                uint hi = row + 1u < OUTPUT_SIZE
                    ? f32_to_bf16(activated_rows[lane * 2u + 1u])
                    : 0u;
                output_frames.words[batch_index * OUTPUT_WORDS + (row >> 1u)] =
                    (hi << 16u) | lo;
            }
        }
        barrier();
    }
}
