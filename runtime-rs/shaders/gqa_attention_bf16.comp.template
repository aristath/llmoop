#version 450

#extension GL_KHR_shader_subgroup_basic : require
#extension GL_KHR_shader_subgroup_arithmetic : require

layout(local_size_x = {{LOCAL_SIZE}}, local_size_y = 1, local_size_z = 1) in;

layout(set = 0, binding = 0) readonly buffer QueryFrame {
    uint words[];
} query_frame;

layout(set = 0, binding = 1) readonly buffer KMemory {
    uint words[];
} k_memory;

layout(set = 0, binding = 2) readonly buffer VMemory {
    uint words[];
} v_memory;

layout(set = 0, binding = 3) buffer OutputFrame {
    uint words[];
} output_frame;

#if {{HAS_SINKS}}
layout(set = 0, binding = 4) readonly buffer AttentionSinks {
    uint words[];
} attention_sinks;
#endif

layout(set = 0, binding = 6) readonly buffer StreamControl {
    uint words[];
} stream_control;

const uint QUERY_HEADS = {{QUERY_HEADS}}u;
const uint KV_HEADS = {{KV_HEADS}}u;
const uint QUERY_GROUPS_PER_KV_HEAD = {{QUERY_GROUPS_PER_KV_HEAD}}u;
const uint HEAD_WIDTH = {{HEAD_WIDTH}}u;
const uint KV_ELEMENT_COUNT = KV_HEADS * HEAD_WIDTH;
const uint SLOT_ELEMENT_COUNT = KV_ELEMENT_COUNT * 2u;
const uint TILE_TOKENS = {{TILE_TOKENS}}u;
const uint PADDED_HEAD_WIDTH = ((HEAD_WIDTH + 63u) / 64u) * 64u;
const uint PHYSICAL_TILE_TOKENS = {{LOCAL_SIZE}}u / PADDED_HEAD_WIDTH;
const uint TOKEN_BATCHES = TILE_TOKENS / PHYSICAL_TILE_TOKENS;
const uint MAX_SUBGROUPS_PER_TOKEN = (HEAD_WIDTH + 31u) / 32u;
const float ATTENTION_SCALE = {{ATTENTION_SCALE}};
const uint ATTENTION_WINDOW = {{ATTENTION_WINDOW}}u;
const float LOWEST_FLOAT = -3.4028234663852886e38;
const uint STATE_PAGE_TABLE_WORDS = 9u;

shared float query_values[{{HEAD_WIDTH}}];
shared float subgroup_partials[{{TILE_TOKENS}} * MAX_SUBGROUPS_PER_TOKEN];
shared float tile_alpha[{{TILE_TOKENS}}];
shared float tile_beta[{{TILE_TOKENS}}];
shared float tile_value_weight[{{TILE_TOKENS}}];
shared float value_contributions[{{TILE_TOKENS}} * {{HEAD_WIDTH}}];
shared float tile_accumulator_carry;
shared float softmax_denominator;
shared float attention_output_scale;
shared float output_values[{{HEAD_WIDTH}}];
shared uint chronological_start;

float bf16_to_f32(uint value) {
    return uintBitsToFloat((value & 0xffffu) << 16);
}

uint f32_to_bf16(float value) {
    uint bits = floatBitsToUint(value);
    uint lsb = (bits >> 16) & 1u;
    uint rounding_bias = 0x7fffu + lsb;
    return (bits + rounding_bias) >> 16;
}

float read_query(uint index) {
    uint packed = query_frame.words[index >> 1];
    uint value = ((index & 1u) == 0u) ? (packed & 0xffffu) : (packed >> 16);
    return bf16_to_f32(value);
}

uint k_memory_word(uint logical_word) {
    uint logical_byte = logical_word * 4u;
    if (logical_byte < k_memory.words[2]) {
        return (k_memory.words[3] + logical_byte) / 4u;
    }
    uint dynamic_byte = logical_byte - k_memory.words[2];
    uint page_bytes = k_memory.words[4];
    uint physical_page =
        k_memory.words[STATE_PAGE_TABLE_WORDS + dynamic_byte / page_bytes];
    return (k_memory.words[8] + physical_page * page_bytes + dynamic_byte % page_bytes) / 4u;
}

uint v_memory_word(uint logical_word) {
    uint logical_byte = logical_word * 4u;
    if (logical_byte < v_memory.words[2]) {
        return (v_memory.words[3] + logical_byte) / 4u;
    }
    uint dynamic_byte = logical_byte - v_memory.words[2];
    uint page_bytes = v_memory.words[4];
    uint physical_page =
        v_memory.words[STATE_PAGE_TABLE_WORDS + dynamic_byte / page_bytes];
    return (v_memory.words[8] + physical_page * page_bytes + dynamic_byte % page_bytes) / 4u;
}

float read_k(uint slot, uint kv_head, uint dim) {
    uint element_index = (slot * SLOT_ELEMENT_COUNT) + (kv_head * HEAD_WIDTH) + dim;
    uint packed = k_memory.words[k_memory_word(element_index >> 1)];
    uint value = ((element_index & 1u) == 0u) ? (packed & 0xffffu) : (packed >> 16);
    return bf16_to_f32(value);
}

float read_v(uint slot, uint kv_head, uint dim) {
    uint element_index = (slot * SLOT_ELEMENT_COUNT) + KV_ELEMENT_COUNT + (kv_head * HEAD_WIDTH) + dim;
    uint packed = v_memory.words[v_memory_word(element_index >> 1)];
    uint value = ((element_index & 1u) == 0u) ? (packed & 0xffffu) : (packed >> 16);
    return bf16_to_f32(value);
}

#if {{HAS_SINKS}}
float read_attention_sink(uint head) {
    uint packed = attention_sinks.words[head >> 1u];
    return bf16_to_f32((head & 1u) == 0u ? packed : packed >> 16);
}
#endif

uint available_tokens(uint capacity) {
    uint tokens = stream_control.words[1] + 1u;
    return min(tokens, capacity);
}

void main() {
    uint query_head = gl_WorkGroupID.x;
    uint local_index = gl_LocalInvocationID.x;
    uint subgroups_per_token = (HEAD_WIDTH + gl_SubgroupSize - 1u) / gl_SubgroupSize;
    uint tile_entry = gl_SubgroupID / subgroups_per_token;
    uint subgroup_part = gl_SubgroupID % subgroups_per_token;
    uint dim = subgroup_part * gl_SubgroupSize + gl_SubgroupInvocationID;
    if (query_head >= QUERY_HEADS) {
        return;
    }

    uint runtime_capacity = stream_control.words[4];
    uint capacity = ATTENTION_WINDOW == 0u
        ? runtime_capacity
        : min(runtime_capacity, ATTENTION_WINDOW);
    uint tokens = capacity == 0u ? 0u : available_tokens(capacity);
    uint kv_head = query_head / QUERY_GROUPS_PER_KV_HEAD;

    if (local_index < HEAD_WIDTH) {
        query_values[local_index] = read_query(query_head * HEAD_WIDTH + local_index);
    }
    if (local_index == 0u) {
        chronological_start = capacity == 0u
            ? 0u
            : (stream_control.words[1] + capacity + 1u - tokens) % capacity;
    }
    barrier();

    float maximum = LOWEST_FLOAT;
    float denominator = 0.0;
    float accumulator = 0.0;

    for (uint tile_start = 0u; tile_start < tokens; tile_start += TILE_TOKENS) {
        for (uint batch = 0u; batch < TOKEN_BATCHES; batch++) {
            uint tile_token = batch * PHYSICAL_TILE_TOKENS + tile_entry;
            uint token_index = tile_start + tile_token;
            float product = 0.0;
            if (
                tile_entry < PHYSICAL_TILE_TOKENS
                && token_index < tokens
                && dim < HEAD_WIDTH
            ) {
                uint slot = chronological_start + token_index;
                if (slot >= capacity) {
                    slot -= capacity;
                }
                product = query_values[dim] * read_k(slot, kv_head, dim);
            }
            float partial = subgroupAdd(product);
            if (
                gl_SubgroupInvocationID == 0u
                && tile_entry < PHYSICAL_TILE_TOKENS
            ) {
                subgroup_partials[
                    tile_token * subgroups_per_token + subgroup_part
                ] = partial;
            }
        }
        barrier();

        if (local_index == 0u) {
            uint tile_count = min(TILE_TOKENS, tokens - tile_start);
            for (uint index = 0u; index < tile_count; index++) {
                float dot_product = 0.0;
                for (uint part = 0u; part < subgroups_per_token; part++) {
                    dot_product += subgroup_partials[index * subgroups_per_token + part];
                }
                float score = dot_product * ATTENTION_SCALE;
                float next_maximum = max(maximum, score);
                float alpha = exp(maximum - next_maximum);
                float beta = exp(score - next_maximum);
                tile_alpha[index] = alpha;
                tile_beta[index] = beta;
                denominator = denominator * alpha + beta;
                maximum = next_maximum;
            }

            float carry = 1.0;
            for (uint reverse = tile_count; reverse > 0u; reverse--) {
                uint index = reverse - 1u;
                tile_value_weight[index] = tile_beta[index] * carry;
                carry *= tile_alpha[index];
            }
            tile_accumulator_carry = carry;
        }
        barrier();

        for (uint batch = 0u; batch < TOKEN_BATCHES; batch++) {
            uint contribution_index =
                batch * PHYSICAL_TILE_TOKENS * HEAD_WIDTH + local_index;
            uint tile_token =
                batch * PHYSICAL_TILE_TOKENS + (local_index / HEAD_WIDTH);
            uint value_token = tile_start + tile_token;
            uint value_dim = local_index % HEAD_WIDTH;
            if (
                local_index < PHYSICAL_TILE_TOKENS * HEAD_WIDTH
                && value_token < tokens
            ) {
                uint slot = chronological_start + value_token;
                if (slot >= capacity) {
                    slot -= capacity;
                }
                value_contributions[contribution_index] =
                    tile_value_weight[tile_token]
                    * read_v(slot, kv_head, value_dim);
            } else if (local_index < PHYSICAL_TILE_TOKENS * HEAD_WIDTH) {
                value_contributions[contribution_index] = 0.0;
            }
        }
        barrier();

        if (local_index < HEAD_WIDTH) {
            uint tile_count = min(TILE_TOKENS, tokens - tile_start);
            float tile_sum = 0.0;
            for (uint index = 0u; index < tile_count; index++) {
                tile_sum += value_contributions[index * HEAD_WIDTH + local_index];
            }
            accumulator = accumulator * tile_accumulator_carry + tile_sum;
        }
        barrier();
    }

    if (local_index == 0u) {
        softmax_denominator = denominator;
#if {{HAS_SINKS}}
        float logsumexp = maximum + log(denominator);
        attention_output_scale = denominator == 0.0
            ? 0.0
            : 1.0 / (1.0 + exp(read_attention_sink(query_head) - logsumexp));
#else
        attention_output_scale = 1.0;
#endif
    }
    barrier();

    if (local_index < HEAD_WIDTH) {
        output_values[local_index] = tokens == 0u || softmax_denominator == 0.0
            ? 0.0
            : (accumulator / softmax_denominator) * attention_output_scale;
    }
    barrier();

    if (local_index < HEAD_WIDTH && (local_index & 1u) == 0u) {
        uint word_index = query_head * (HEAD_WIDTH / 2u) + (local_index / 2u);
        output_frame.words[word_index] =
            (f32_to_bf16(output_values[local_index + 1u]) << 16)
            | f32_to_bf16(output_values[local_index]);
    }
}
