#version 450

layout(local_size_x = 64, local_size_y = 1, local_size_z = 1) in;

layout(push_constant) uniform StreamControl {
    uint stream_tick_lo;
    uint stream_tick_hi;
    uint control_flags;
    uint dynamic_state_capacity_activations;
} control;

layout(set = 0, binding = 0) readonly buffer QueryFrame {
    uint words[];
} query_frame;

layout(set = 0, binding = 1) readonly buffer KMemory {
    uint words[];
} k_memory;

layout(set = 0, binding = 2) readonly buffer VMemory {
    uint words[];
} v_memory;

layout(set = 0, binding = 3) buffer OutputFrame {
    uint words[];
} output_frame;

const uint QUERY_HEADS = 16u;
const uint KV_HEADS = 8u;
const uint QUERY_GROUPS_PER_KV_HEAD = 2u;
const uint HEAD_WIDTH = 64u;
const uint KV_ELEMENT_COUNT = KV_HEADS * HEAD_WIDTH;
const uint SLOT_ELEMENT_COUNT = KV_ELEMENT_COUNT * 2u;
const uint OUTPUT_WORD_COUNT = (QUERY_HEADS * HEAD_WIDTH) / 2u;
const uint MAX_CAPACITY = 4u;
const float ATTENTION_SCALE = 0.125;

float bf16_to_f32(uint value) {
    return uintBitsToFloat((value & 0xffffu) << 16);
}

uint f32_to_bf16(float value) {
    uint bits = floatBitsToUint(value);
    uint lsb = (bits >> 16) & 1u;
    uint rounding_bias = 0x7fffu + lsb;
    return (bits + rounding_bias) >> 16;
}

float read_query(uint index) {
    uint packed = query_frame.words[index >> 1];
    uint value = ((index & 1u) == 0u) ? (packed & 0xffffu) : (packed >> 16);
    return bf16_to_f32(value);
}

float read_k(uint slot, uint kv_head, uint dim) {
    uint element_index = (slot * SLOT_ELEMENT_COUNT) + (kv_head * HEAD_WIDTH) + dim;
    uint packed = k_memory.words[element_index >> 1];
    uint value = ((element_index & 1u) == 0u) ? (packed & 0xffffu) : (packed >> 16);
    return bf16_to_f32(value);
}

float read_v(uint slot, uint kv_head, uint dim) {
    uint element_index = (slot * SLOT_ELEMENT_COUNT) + KV_ELEMENT_COUNT + (kv_head * HEAD_WIDTH) + dim;
    uint packed = v_memory.words[element_index >> 1];
    uint value = ((element_index & 1u) == 0u) ? (packed & 0xffffu) : (packed >> 16);
    return bf16_to_f32(value);
}

uint bounded_capacity() {
    uint capacity = control.dynamic_state_capacity_activations;
    if (capacity > MAX_CAPACITY) {
        return MAX_CAPACITY;
    }
    return capacity;
}

uint available_tokens(uint capacity) {
    uint tokens = control.stream_tick_lo + 1u;
    if (tokens > capacity) {
        return capacity;
    }
    return tokens;
}

uint chronological_slot(uint index, uint capacity, uint tokens) {
    uint start = (control.stream_tick_lo + capacity + 1u - tokens) % capacity;
    return (start + index) % capacity;
}

float attention_score(uint query_head, uint kv_head, uint slot) {
    float sum = 0.0;
    uint query_base = query_head * HEAD_WIDTH;
    for (uint dim = 0u; dim < HEAD_WIDTH; dim = dim + 1u) {
        sum = sum + read_query(query_base + dim) * read_k(slot, kv_head, dim);
    }
    return sum * ATTENTION_SCALE;
}

float attention_value(uint query_head, uint dim) {
    uint capacity = bounded_capacity();
    if (capacity == 0u) {
        return 0.0;
    }
    uint tokens = available_tokens(capacity);
    uint kv_head = query_head / QUERY_GROUPS_PER_KV_HEAD;

    float scores[MAX_CAPACITY];
    float max_score = -3.4028234663852886e38;
    for (uint index = 0u; index < tokens; index = index + 1u) {
        uint slot = chronological_slot(index, capacity, tokens);
        float score = attention_score(query_head, kv_head, slot);
        scores[index] = score;
        if (score > max_score) {
            max_score = score;
        }
    }

    float denominator = 0.0;
    for (uint index = 0u; index < tokens; index = index + 1u) {
        denominator = denominator + exp(scores[index] - max_score);
    }
    if (denominator == 0.0) {
        return 0.0;
    }

    float result = 0.0;
    for (uint index = 0u; index < tokens; index = index + 1u) {
        uint slot = chronological_slot(index, capacity, tokens);
        float weight = exp(scores[index] - max_score) / denominator;
        result = result + weight * read_v(slot, kv_head, dim);
    }
    return result;
}

void main() {
    if (gl_GlobalInvocationID.x != 0u) {
        return;
    }

    for (uint word_index = 0u; word_index < OUTPUT_WORD_COUNT; word_index = word_index + 1u) {
        uint lo_element = word_index * 2u;
        uint hi_element = lo_element + 1u;
        uint lo_head = lo_element / HEAD_WIDTH;
        uint hi_head = hi_element / HEAD_WIDTH;
        uint lo_dim = lo_element % HEAD_WIDTH;
        uint hi_dim = hi_element % HEAD_WIDTH;
        float lo = attention_value(lo_head, lo_dim);
        float hi = attention_value(hi_head, hi_dim);
        output_frame.words[word_index] = (f32_to_bf16(hi) << 16) | f32_to_bf16(lo);
    }
}
