#version 450

layout(local_size_x = 1, local_size_y = 1, local_size_z = 1) in;

layout(set = 0, binding = 0) readonly buffer StreamControl {
    uint words[];
} stream_control;

layout(set = 0, binding = 1) buffer SeenTokens {
    uint words[];
} seen_tokens;

const uint VOCAB_SIZE = {{VOCAB_SIZE}}u;

void main() {
    uint token_id = stream_control.words[0];
    if (token_id < VOCAB_SIZE) {
        atomicOr(seen_tokens.words[token_id >> 5u], 1u << (token_id & 31u));
    }
}
