#version 460

#extension GL_KHR_shader_subgroup_basic : require
#extension GL_KHR_shader_subgroup_arithmetic : require
#extension GL_KHR_shader_subgroup_clustered : require
#extension GL_EXT_shader_explicit_arithmetic_types_int8 : require
#extension GL_EXT_spirv_intrinsics : require

spirv_instruction(
    extensions = ["SPV_KHR_integer_dot_product"],
    capabilities = [6019],
    id = 4450
)
int int8_dot4(i8vec4 a, i8vec4 b);

layout(local_size_x = 64, local_size_y = 1, local_size_z = 1) in;

layout(set = 0, binding = 0) readonly buffer InputFrames { uint words[]; } input_frames;
layout(set = 0, binding = {{OUTPUT_BINDING}}) buffer OutputFrames { uint words[]; } output_frames;
layout(set = 0, binding = {{QWEIGHT_BINDING}}) readonly buffer QWeight { uint words[]; } qweight;
layout(set = 0, binding = {{SCALES_BINDING}}) readonly buffer Scales { uint words[]; } scales;
{{AUXILIARY_BUFFER}}

{{BATCH_CONTROL}}

const uint BATCH_TILE_WIDTH = {{BATCH_TILE_WIDTH}}u;
const uint GROUP_SIZE = {{GROUP_SIZE}}u;
const uint INPUT_SIZE = {{INPUT_SIZE}}u;
const uint OUTPUT_SIZE = {{OUTPUT_SIZE}}u;
const uint ACTIVATION_BLOCK_WIDTH = {{ACTIVATION_BLOCK_WIDTH}}u;
const uint OUTPUT_TILE_ROWS = {{OUTPUT_TILE_ROWS}}u;
const uint INPUT_WORDS = INPUT_SIZE / 2u;
const uint OUTPUT_WORDS = OUTPUT_SIZE / 2u;
const uint PACKED_COLUMNS = INPUT_SIZE / 8u;
const uint SCALE_COLUMNS = INPUT_SIZE / GROUP_SIZE;
const uint ACTIVATION_BLOCKS = INPUT_SIZE / ACTIVATION_BLOCK_WIDTH;
const uint ACTIVATION_WORDS_PER_BLOCK = ACTIVATION_BLOCK_WIDTH / 4u;
const uint PACKED_COLUMNS_PER_BLOCK = ACTIVATION_BLOCK_WIDTH / 8u;

shared i8vec4 quantized_input[INPUT_SIZE / 4u];
shared float input_scales[ACTIVATION_BLOCKS];
shared float subgroup_sum[OUTPUT_TILE_ROWS][64];
shared float output_rows[OUTPUT_TILE_ROWS];

float bf16_to_f32(uint value) {
    return uintBitsToFloat((value & 0xffffu) << 16u);
}

float read_bf16_word(uint packed, uint index) {
    return bf16_to_f32(packed >> ((index & 1u) * 16u));
}

vec4 read_inputx4(uint batch_index, uint column) {
    uint offset = batch_index * INPUT_WORDS + (column >> 1u);
    uint lo = input_frames.words[offset];
    uint hi = input_frames.words[offset + 1u];
    return vec4(
        bf16_to_f32(lo),
        bf16_to_f32(lo >> 16u),
        bf16_to_f32(hi),
        bf16_to_f32(hi >> 16u)
    );
}

float read_weight_scale(uint row, uint group) {
    uint index = row * SCALE_COLUMNS + group;
{{READ_SCALE_BODY}}
}

i8vec4 unpack_weight_lo(uint packed) {
    return i8vec4(
        int(packed & 15u) - 8,
        int((packed >> 4u) & 15u) - 8,
        int((packed >> 8u) & 15u) - 8,
        int((packed >> 12u) & 15u) - 8
    );
}

i8vec4 unpack_weight_hi(uint packed) {
    return i8vec4(
        int((packed >> 16u) & 15u) - 8,
        int((packed >> 20u) & 15u) - 8,
        int((packed >> 24u) & 15u) - 8,
        int((packed >> 28u) & 15u) - 8
    );
}

uint f32_to_bf16(float value) {
    uint bits = floatBitsToUint(value);
    uint lsb = (bits >> 16u) & 1u;
    return (bits + 0x7fffu + lsb) >> 16u;
}

{{FINALIZE_OUTPUT_FUNCTION}}

void quantize_input(uint batch_index, uint lane) {
    uint cluster = lane >> 5u;
    uint cluster_lane = lane & 31u;
    for (uint block = cluster; block < ACTIVATION_BLOCKS; block += 2u) {
        vec4 input_value = vec4(0.0);
        if (cluster_lane < ACTIVATION_WORDS_PER_BLOCK) {
            uint column = block * ACTIVATION_BLOCK_WIDTH + cluster_lane * 4u;
            input_value = read_inputx4(batch_index, column);
        }
        float lane_max = max(
            max(abs(input_value.x), abs(input_value.y)),
            max(abs(input_value.z), abs(input_value.w))
        );
        float block_max = subgroupClusteredMax(lane_max, 32u);
        float scale = block_max > 0.0 ? block_max / 127.0 : 1.0;
        if (cluster_lane == 0u) {
            input_scales[block] = scale;
        }
        if (cluster_lane < ACTIVATION_WORDS_PER_BLOCK) {
            vec4 rounded = clamp(
                round(input_value / scale), vec4(-127.0), vec4(127.0)
            );
            quantized_input[
                block * ACTIVATION_WORDS_PER_BLOCK + cluster_lane
            ] = i8vec4(rounded);
        }
    }
}

void project_rows(uint first_row, uint lane) {
    for (uint local_row = 0u; local_row < OUTPUT_TILE_ROWS; local_row++) {
        uint row = first_row + local_row;
        float sum = 0.0;
        if (row < OUTPUT_SIZE) {
            for (
                uint packed_column = lane;
                packed_column < PACKED_COLUMNS;
                packed_column += 64u
            ) {
                uint packed = qweight.words[row * PACKED_COLUMNS + packed_column];
                uint input_word = packed_column * 2u;
                int packed_sum = int8_dot4(
                    quantized_input[input_word], unpack_weight_lo(packed)
                ) + int8_dot4(
                    quantized_input[input_word + 1u], unpack_weight_hi(packed)
                );
                uint block = packed_column / PACKED_COLUMNS_PER_BLOCK;
                uint group = (packed_column * 8u) / GROUP_SIZE;
                sum = fma(
                    float(packed_sum),
                    input_scales[block] * read_weight_scale(row, group),
                    sum
                );
            }
        }
        sum = subgroupAdd(sum);
        if (gl_SubgroupInvocationID == 0u) {
            subgroup_sum[local_row][gl_SubgroupID] = sum;
        }
    }
}

void main() {
    uint lane = gl_LocalInvocationID.x;
    uint first_row = gl_WorkGroupID.x * OUTPUT_TILE_ROWS;
    uint batch_start = {{BATCH_START}};
    uint batch_width = {{BATCH_WIDTH}};

    for (uint batch_lane = 0u; batch_lane < BATCH_TILE_WIDTH; batch_lane++) {
        uint batch_index = batch_start + batch_lane;
        if (batch_index >= batch_width) {
            break;
        }
        quantize_input(batch_index, lane);
        barrier();

        project_rows(first_row, lane);
        barrier();

        if (lane < OUTPUT_TILE_ROWS) {
            uint row = first_row + lane;
            float sum = 0.0;
            for (uint subgroup = 0u; subgroup < gl_NumSubgroups; subgroup++) {
                sum += subgroup_sum[lane][subgroup];
            }
            output_rows[lane] = row < OUTPUT_SIZE
                ? finalize_output(batch_index, row, sum)
                : 0.0;
        }
        barrier();

        if (lane < OUTPUT_TILE_ROWS / 2u) {
            uint row = first_row + lane * 2u;
            if (row < OUTPUT_SIZE) {
                uint hi = row + 1u < OUTPUT_SIZE
                    ? f32_to_bf16(output_rows[lane * 2u + 1u])
                    : 0u;
                output_frames.words[batch_index * OUTPUT_WORDS + row / 2u] =
                    (hi << 16u) | f32_to_bf16(output_rows[lane * 2u]);
            }
        }
        barrier();
    }
}
