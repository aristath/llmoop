#version 450

layout(local_size_x = 64, local_size_y = 1, local_size_z = 1) in;

layout(set = 0, binding = 0) readonly buffer CurrentFrame {
    uint words[];
} current_frame;

layout(set = 0, binding = 1) readonly buffer InputState {
    uint words[];
} input_state;

layout(set = 0, binding = 2) buffer WindowOut {
    uint words[];
} window_out;

layout(set = 0, binding = 3) readonly buffer StateRead {
    uint words[];
} state_read;

layout(set = 0, binding = 4) buffer StateWrite {
    uint words[];
} state_write;

layout(set = 0, binding = 5) buffer StateView {
    uint words[];
} state_view;

const uint FRAME_WORD_COUNT = 512u;

void main() {
    for (uint word_index = gl_LocalInvocationID.x; word_index < FRAME_WORD_COUNT; word_index += 64u) {
        uint shifted_0 = state_read.words[FRAME_WORD_COUNT + word_index];
        uint shifted_1 = state_read.words[(2u * FRAME_WORD_COUNT) + word_index];
        uint appended = current_frame.words[word_index];

        window_out.words[word_index] = shifted_0;
        window_out.words[FRAME_WORD_COUNT + word_index] = shifted_1;
        window_out.words[(2u * FRAME_WORD_COUNT) + word_index] = appended;

        state_write.words[word_index] = shifted_0;
        state_write.words[FRAME_WORD_COUNT + word_index] = shifted_1;
        state_write.words[(2u * FRAME_WORD_COUNT) + word_index] = appended;

        state_view.words[word_index] = shifted_0;
        state_view.words[FRAME_WORD_COUNT + word_index] = shifted_1;
        state_view.words[(2u * FRAME_WORD_COUNT) + word_index] = appended;
    }
}
