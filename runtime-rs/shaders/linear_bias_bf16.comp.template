#version 450

#extension GL_KHR_shader_subgroup_basic : require
#extension GL_KHR_shader_subgroup_arithmetic : require

layout(local_size_x = 64, local_size_y = 1, local_size_z = 1) in;

layout(set = 0, binding = 0) readonly buffer InputFrame { uint words[]; } input_frame;
layout(set = 0, binding = 1) buffer OutputFrame { uint words[]; } output_frame;
layout(set = 0, binding = 2) readonly buffer Weight { uint words[]; } weight;
layout(set = 0, binding = 3) readonly buffer Bias { uint words[]; } bias;

const uint INPUT_SIZE = {{INPUT_SIZE}}u;
const uint OUTPUT_SIZE = {{OUTPUT_SIZE}}u;
const uint OUTPUT_WORDS = (OUTPUT_SIZE + 1u) / 2u;
const uint INPUT_WORDS = (INPUT_SIZE + 1u) / 2u;

shared float subgroup_lo[64];
shared float subgroup_hi[64];

float bf16_to_f32(uint value) { return uintBitsToFloat((value & 0xffffu) << 16); }
uint f32_to_bf16(float value) {
    uint bits = floatBitsToUint(value);
    uint lsb = (bits >> 16) & 1u;
    return (bits + 0x7fffu + lsb) >> 16;
}
float read_bias(uint row) {
    uint packed = bias.words[row >> 1u];
    return bf16_to_f32((row & 1u) == 0u ? packed : packed >> 16);
}
void store_result(uint word_index, uint hi_row, float lo_sum, float hi_sum) {
    uint lo = f32_to_bf16(lo_sum + read_bias(word_index * 2u));
    uint hi = hi_row < OUTPUT_SIZE ? f32_to_bf16(hi_sum + read_bias(hi_row)) : 0u;
    output_frame.words[word_index] = (hi << 16) | lo;
}
void main() {
    uint word_index = gl_WorkGroupID.x;
    uint lane = gl_LocalInvocationID.x;
    uint lo_row = word_index * 2u;
    uint hi_row = lo_row + 1u;
    float lo_sum = 0.0;
    float hi_sum = 0.0;
    if (word_index < OUTPUT_WORDS) {
        uint lo_offset = lo_row * INPUT_WORDS;
        uint hi_offset = hi_row * INPUT_WORDS;
        for (uint column_word = lane; column_word < INPUT_WORDS; column_word += 64u) {
            uint input_pair = input_frame.words[column_word];
            float input_lo = bf16_to_f32(input_pair);
            float input_hi = bf16_to_f32(input_pair >> 16);
            uint lo_weight = weight.words[lo_offset + column_word];
            lo_sum = fma(input_lo, bf16_to_f32(lo_weight), lo_sum);
            lo_sum = fma(input_hi, bf16_to_f32(lo_weight >> 16), lo_sum);
            if (hi_row < OUTPUT_SIZE) {
                uint hi_weight = weight.words[hi_offset + column_word];
                hi_sum = fma(input_lo, bf16_to_f32(hi_weight), hi_sum);
                hi_sum = fma(input_hi, bf16_to_f32(hi_weight >> 16), hi_sum);
            }
        }
    }
    lo_sum = subgroupAdd(lo_sum);
    hi_sum = subgroupAdd(hi_sum);
    if (gl_NumSubgroups == 1u) {
        if (gl_SubgroupInvocationID == 0u && word_index < OUTPUT_WORDS) {
            store_result(word_index, hi_row, lo_sum, hi_sum);
        }
        return;
    }
    if (gl_SubgroupInvocationID == 0u) {
        subgroup_lo[gl_SubgroupID] = lo_sum;
        subgroup_hi[gl_SubgroupID] = hi_sum;
    }
    barrier();
    if (lane == 0u && word_index < OUTPUT_WORDS) {
        float lo_total = 0.0;
        float hi_total = 0.0;
        for (uint subgroup = 0u; subgroup < gl_NumSubgroups; subgroup++) {
            lo_total += subgroup_lo[subgroup];
            hi_total += subgroup_hi[subgroup];
        }
        store_result(word_index, hi_row, lo_total, hi_total);
    }
}
