#version 460

#extension GL_KHR_shader_subgroup_basic : require
#extension GL_KHR_shader_subgroup_arithmetic : require

layout(local_size_x = 64, local_size_y = 1, local_size_z = 1) in;

layout(set = 0, binding = 0) readonly buffer HiddenFrames { uint words[]; } hidden_frames;
layout(set = 0, binding = 1) readonly buffer ExpertRoutes { uint words[]; } expert_routes;
layout(set = 0, binding = 2) buffer ExpertIntermediates { uint words[]; } expert_intermediates;
layout(set = 0, binding = 3) readonly buffer ExpertInputWeight { uint words[]; } expert_input_weight;
layout(set = 0, binding = 4) readonly buffer ExpertInputScales { uint words[]; } expert_input_scales;

{{BATCH_CONTROL}}

const uint GROUP_SIZE = {{GROUP_SIZE}}u;
const uint HIDDEN_SIZE = {{HIDDEN_SIZE}}u;
const uint INTERMEDIATE_SIZE = {{INTERMEDIATE_SIZE}}u;
const uint NUM_EXPERTS = {{NUM_EXPERTS}}u;
const uint EXPERTS_PER_TOKEN = {{EXPERTS_PER_TOKEN}}u;
const uint TILE_ROWS = {{TILE_ROWS}}u;
const uint TILES_PER_ROUTE = (INTERMEDIATE_SIZE + TILE_ROWS - 1u) / TILE_ROWS;
const uint HIDDEN_WORDS = HIDDEN_SIZE / 2u;
const uint PACKED_COLUMNS = HIDDEN_SIZE / 8u;
const uint SCALE_COLUMNS = HIDDEN_SIZE / GROUP_SIZE;
const uint INTERMEDIATE_WORDS = INTERMEDIATE_SIZE / 2u;
const uint EXPERT_INPUT_ROWS = INTERMEDIATE_SIZE * 2u;
const uint EXPERT_INPUT_WORDS = EXPERT_INPUT_ROWS * PACKED_COLUMNS;

shared float subgroup_gate[TILE_ROWS][64];
shared float subgroup_up[TILE_ROWS][64];
shared float activated_rows[TILE_ROWS];

float bf16_to_f32(uint value) {
    return uintBitsToFloat((value & 0xffffu) << 16u);
}

float read_bf16_word(uint packed, uint index) {
    return bf16_to_f32(packed >> ((index & 1u) * 16u));
}

uint f32_to_bf16(float value) {
    uint bits = floatBitsToUint(value);
    uint lsb = (bits >> 16u) & 1u;
    return (bits + 0x7fffu + lsb) >> 16u;
}

float round_bf16(float value) {
    return bf16_to_f32(f32_to_bf16(value));
}

vec4 read_hiddenx4(uint batch_index, uint column) {
    uint offset = batch_index * HIDDEN_WORDS + (column >> 1u);
    uint lo = hidden_frames.words[offset];
    uint hi = hidden_frames.words[offset + 1u];
    return vec4(
        bf16_to_f32(lo),
        bf16_to_f32(lo >> 16u),
        bf16_to_f32(hi),
        bf16_to_f32(hi >> 16u)
    );
}

float read_scale(uint expert, uint row, uint group) {
    uint index = (expert * EXPERT_INPUT_ROWS + row) * SCALE_COLUMNS + group;
{{READ_SCALE_BODY}}
}

vec4 unpack_weight_lo(uint packed) {
    return vec4(
        float(int(packed & 15u) - 8),
        float(int((packed >> 4u) & 15u) - 8),
        float(int((packed >> 8u) & 15u) - 8),
        float(int((packed >> 12u) & 15u) - 8)
    );
}

vec4 unpack_weight_hi(uint packed) {
    return vec4(
        float(int((packed >> 16u) & 15u) - 8),
        float(int((packed >> 20u) & 15u) - 8),
        float(int((packed >> 24u) & 15u) - 8),
        float(int((packed >> 28u) & 15u) - 8)
    );
}

float project_row(uint batch_index, uint expert, uint row, uint lane) {
    float sum = 0.0;
    for (uint packed_column = lane; packed_column < PACKED_COLUMNS; packed_column += 64u) {
        uint packed = expert_input_weight.words[
            (expert * EXPERT_INPUT_ROWS + row) * PACKED_COLUMNS + packed_column
        ];
        uint group = packed_column * 8u / GROUP_SIZE;
        sum = fma(
            dot(
                read_hiddenx4(batch_index, packed_column * 8u),
                unpack_weight_lo(packed)
            ) + dot(
                read_hiddenx4(batch_index, packed_column * 8u + 4u),
                unpack_weight_hi(packed)
            ),
            read_scale(expert, row, group),
            sum
        );
    }
    return subgroupAdd(sum);
}

void main() {
    uint batch_index = {{BATCH_INDEX}};
    uint group = gl_WorkGroupID.x;
    uint route = group / TILES_PER_ROUTE;
    uint tile = group % TILES_PER_ROUTE;
    if (batch_index >= {{BATCH_WIDTH}} || route >= EXPERTS_PER_TOKEN) return;
    uint route_offset = batch_index * EXPERTS_PER_TOKEN;
    uint expert = expert_routes.words[route_offset + route] & 0xffffu;
    if (expert >= NUM_EXPERTS) return;
    uint expert_start = gl_WorkGroupID.z;
    uint expert_count = expert_input_weight.words.length() / EXPERT_INPUT_WORDS;
    if (expert < expert_start || expert >= expert_start + expert_count) return;
    expert -= expert_start;

    uint lane = gl_LocalInvocationID.x;
    uint first_row = tile * TILE_ROWS;
    for (uint local_row = 0u; local_row < TILE_ROWS; local_row++) {
        uint row = first_row + local_row;
        float gate = 0.0;
        float up = 0.0;
        if (row < INTERMEDIATE_SIZE) {
            gate = project_row(batch_index, expert, row, lane);
            up = project_row(batch_index, expert, INTERMEDIATE_SIZE + row, lane);
        }
        if (gl_SubgroupInvocationID == 0u) {
            subgroup_gate[local_row][gl_SubgroupID] = gate;
            subgroup_up[local_row][gl_SubgroupID] = up;
        }
    }
    barrier();

    if (lane < TILE_ROWS) {
        uint row = first_row + lane;
        float gate = 0.0;
        float up = 0.0;
        for (uint subgroup = 0u; subgroup < gl_NumSubgroups; subgroup++) {
            gate += subgroup_gate[lane][subgroup];
            up += subgroup_up[lane][subgroup];
        }
        if (row < INTERMEDIATE_SIZE) {
            gate = round_bf16(gate);
            up = round_bf16(up);
            activated_rows[lane] = round_bf16(
                round_bf16(gate / (1.0 + exp(-gate))) * up
            );
        } else {
            activated_rows[lane] = 0.0;
        }
    }
    barrier();

    if (lane < TILE_ROWS / 2u) {
        uint row = first_row + lane * 2u;
        if (row < INTERMEDIATE_SIZE) {
            uint hi = row + 1u < INTERMEDIATE_SIZE
                ? f32_to_bf16(activated_rows[lane * 2u + 1u])
                : 0u;
            expert_intermediates.words[
                (route_offset + route) * INTERMEDIATE_WORDS + row / 2u
            ] = (hi << 16u) | f32_to_bf16(activated_rows[lane * 2u]);
        }
    }
}
