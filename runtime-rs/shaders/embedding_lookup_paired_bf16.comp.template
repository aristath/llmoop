#version 450

layout(local_size_x = 256, local_size_y = 1, local_size_z = 1) in;

layout(set = 0, binding = 0) readonly buffer EmbeddingWeight {
    uvec2 words[];
} embedding_weight;

layout(set = 0, binding = 1) buffer OutputFrame {
    uint words[];
} output_frame;

layout(set = 0, binding = 2) readonly buffer StreamControl {
    uint words[];
} stream_control;

const uint VOCAB_SIZE = {{VOCAB_SIZE}}u;
const uint FRAME_WORDS = ({{HIDDEN_SIZE}}u + 1u) / 2u;
const float EMBEDDING_SCALE = {{EMBEDDING_SCALE}};

float bf16_to_f32(uint value) {
    return uintBitsToFloat((value & 0xffffu) << 16);
}

uint f32_to_bf16(float value) {
    uint bits = floatBitsToUint(value);
    uint lsb = (bits >> 16) & 1u;
    return (bits + 0x7fffu + lsb) >> 16;
}

void main() {
    uint word_index = gl_GlobalInvocationID.x;
    if (word_index >= FRAME_WORDS) {
        return;
    }
    uint token_id = stream_control.words[0];
    if (token_id >= VOCAB_SIZE) {
        return;
    }

    uint row_pair = token_id / 2u;
    uvec2 pair = embedding_weight.words[row_pair * FRAME_WORDS + word_index];
    uint packed = ((token_id & 1u) == 0u) ? pair.x : pair.y;
    uint lo = f32_to_bf16(bf16_to_f32(packed) * EMBEDDING_SCALE);
    uint hi = f32_to_bf16(bf16_to_f32(packed >> 16) * EMBEDDING_SCALE);
    output_frame.words[word_index] = (hi << 16) | lo;
}
