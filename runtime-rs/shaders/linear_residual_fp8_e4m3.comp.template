#version 460

#extension GL_KHR_shader_subgroup_basic : require
#extension GL_KHR_shader_subgroup_arithmetic : require
#extension GL_KHR_shader_subgroup_clustered : require
#extension GL_EXT_shader_explicit_arithmetic_types_int8 : require
#extension GL_EXT_float_e4m3 : require
#extension GL_EXT_spirv_intrinsics : require

spirv_instruction(
    extensions = ["SPV_VALVE_mixed_float_dot_product"],
    capabilities = [6915],
    id = 6918
)
float fp8_dot4_acc32(fe4m3vec4 a, fe4m3vec4 b, float accumulator);

layout(local_size_x = 64, local_size_y = 1, local_size_z = 1) in;

layout(set = 0, binding = 0) readonly buffer InputFrame { uint words[]; } input_frame;
layout(set = 0, binding = 1) readonly buffer ResidualFrame { uint words[]; } residual_frame;
layout(set = 0, binding = 2) buffer OutputFrame { uint words[]; } output_frame;
layout(set = 0, binding = 3) readonly buffer Weight { uint words[]; } weight;
layout(set = 0, binding = 4) readonly buffer WeightScaleInv { uint words[]; } weight_scale_inv;

const uint BLOCK_ROWS = {{BLOCK_ROWS}}u;
const uint BLOCK_COLUMNS = {{BLOCK_COLUMNS}}u;
const uint INPUT_SIZE = {{INPUT_SIZE}}u;
const uint OUTPUT_SIZE = {{OUTPUT_SIZE}}u;
const uint OUTPUT_TILE_ROWS = {{OUTPUT_TILE_ROWS}}u;
const uint INPUT_FP8_WORDS = INPUT_SIZE / 4u;
const uint INPUT_BLOCKS = INPUT_SIZE / BLOCK_COLUMNS;
const uint BLOCK_FP8_WORDS = BLOCK_COLUMNS / 4u;
const uint SCALE_COLUMNS = INPUT_BLOCKS;

shared fe4m3vec4 quantized_input[INPUT_FP8_WORDS];
shared float input_scales[INPUT_BLOCKS];
shared float subgroup_sum[OUTPUT_TILE_ROWS][64];
shared float output_rows[OUTPUT_TILE_ROWS];

float bf16_to_f32(uint value) { return uintBitsToFloat((value & 0xffffu) << 16); }

uint f32_to_bf16(float value) {
    uint bits = floatBitsToUint(value);
    uint lsb = (bits >> 16u) & 1u;
    return (bits + 0x7fffu + lsb) >> 16u;
}

float read_bf16_word(uint packed, uint index) {
    return bf16_to_f32(packed >> ((index & 1u) * 16u));
}

vec4 read_inputx4(uint column) {
    uint offset = column >> 1u;
    uint lo = input_frame.words[offset];
    uint hi = input_frame.words[offset + 1u];
    return vec4(
        bf16_to_f32(lo),
        bf16_to_f32(lo >> 16u),
        bf16_to_f32(hi),
        bf16_to_f32(hi >> 16u)
    );
}

float read_weight_scale(uint row, uint block) {
    uint index = (row / BLOCK_ROWS) * SCALE_COLUMNS + block;
    return read_bf16_word(weight_scale_inv.words[index >> 1u], index);
}

fe4m3vec4 read_weightx4(uint row, uint column) {
    uint index = row * INPUT_SIZE + column;
    uint packed = weight.words[index >> 2u];
    return uintBitsToFloate4m3EXT(u8vec4(
        uint8_t(packed),
        uint8_t(packed >> 8u),
        uint8_t(packed >> 16u),
        uint8_t(packed >> 24u)
    ));
}

void main() {
    uint lane = gl_LocalInvocationID.x;
    uint cluster = lane >> 5u;
    uint cluster_lane = lane & 31u;
    for (uint block = cluster; block < INPUT_BLOCKS; block += 2u) {
        uint word = block * BLOCK_FP8_WORDS + cluster_lane;
        vec4 input_value = read_inputx4(word * 4u);
        float lane_max = max(
            max(abs(input_value.x), abs(input_value.y)),
            max(abs(input_value.z), abs(input_value.w))
        );
        float block_max = subgroupClusteredMax(lane_max, 32u);
        float scale = block_max > 0.0 ? block_max / 448.0 : 1.0;
        if (cluster_lane == 0u) {
            input_scales[block] = scale;
        }
        quantized_input[word] = fe4m3vec4(input_value / scale);
    }
    barrier();

    uint first_row = gl_WorkGroupID.x * OUTPUT_TILE_ROWS;
    for (uint local_row = 0u; local_row < OUTPUT_TILE_ROWS; local_row++) {
        uint row = first_row + local_row;
        float sum = 0.0;
        if (row < OUTPUT_SIZE) {
            for (uint word = lane; word < INPUT_FP8_WORDS; word += 64u) {
                uint block = word / BLOCK_FP8_WORDS;
                sum = fma(
                    fp8_dot4_acc32(
                        quantized_input[word],
                        read_weightx4(row, word * 4u),
                        0.0
                    ),
                    input_scales[block] * read_weight_scale(row, block),
                    sum
                );
            }
        }
        sum = subgroupAdd(sum);
        if (gl_SubgroupInvocationID == 0u) {
            subgroup_sum[local_row][gl_SubgroupID] = sum;
        }
    }
    barrier();

    if (lane < OUTPUT_TILE_ROWS) {
        uint row = first_row + lane;
        float sum = 0.0;
        for (uint subgroup = 0u; subgroup < gl_NumSubgroups; subgroup++) {
            sum += subgroup_sum[lane][subgroup];
        }
        output_rows[lane] = row < OUTPUT_SIZE
            ? read_bf16_word(residual_frame.words[row >> 1u], row) + sum
            : 0.0;
    }
    barrier();

    if (lane < OUTPUT_TILE_ROWS / 2u) {
        uint row = first_row + lane * 2u;
        if (row < OUTPUT_SIZE) {
            uint hi = row + 1u < OUTPUT_SIZE
                ? f32_to_bf16(output_rows[lane * 2u + 1u])
                : 0u;
            output_frame.words[row / 2u] =
                (hi << 16u) | f32_to_bf16(output_rows[lane * 2u]);
        }
    }
}
