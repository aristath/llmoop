#version 450

layout(local_size_x = 64, local_size_y = 1, local_size_z = 1) in;

layout(set = 0, binding = 0) readonly buffer ValueInput {
    uint words[];
} value_input;

layout(set = 0, binding = 1) readonly buffer GateInput {
    uint words[];
} gate_input;

layout(set = 0, binding = 2) buffer OutputFrame {
    uint words[];
} output_frame;

const uint QUERY_HEADS = {{QUERY_HEADS}}u;
const uint HEAD_WIDTH = {{HEAD_WIDTH}}u;
const bool PER_HEAD = {{PER_HEAD}} != 0;

float bf16_to_f32(uint value) {
    return uintBitsToFloat((value & 0xffffu) << 16);
}

uint f32_to_bf16(float value) {
    uint bits = floatBitsToUint(value);
    uint lsb = (bits >> 16) & 1u;
    return (bits + 0x7fffu + lsb) >> 16;
}

float read_gate(uint element) {
    uint index = PER_HEAD ? element / HEAD_WIDTH : element;
    uint packed = gate_input.words[index >> 1u];
    return bf16_to_f32((index & 1u) == 0u ? packed : packed >> 16);
}

float softplus(float value) {
    return value > 20.0 ? value : log(1.0 + exp(value));
}

void main() {
    const uint word_count = QUERY_HEADS * HEAD_WIDTH / 2u;
    for (uint word_index = gl_LocalInvocationID.x;
         word_index < word_count;
         word_index += 64u) {
        uint value = value_input.words[word_index];
        uint lo_element = word_index * 2u;
        uint hi_element = lo_element + 1u;
        float lo = bf16_to_f32(value) * softplus(read_gate(lo_element));
        float hi = bf16_to_f32(value >> 16) * softplus(read_gate(hi_element));
        output_frame.words[word_index] =
            (f32_to_bf16(hi) << 16u) | f32_to_bf16(lo);
    }
}
