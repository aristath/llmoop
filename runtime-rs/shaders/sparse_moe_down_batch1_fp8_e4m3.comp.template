#version 460

#extension GL_KHR_shader_subgroup_basic : require
#extension GL_KHR_shader_subgroup_arithmetic : require
#extension GL_EXT_shader_explicit_arithmetic_types_int8 : require
#extension GL_EXT_float_e4m3 : require

layout(local_size_x = 64, local_size_y = 1, local_size_z = 1) in;

layout(set = 0, binding = 0) readonly buffer ExpertIntermediates { uint words[]; } expert_intermediates;
layout(set = 0, binding = 1) readonly buffer ExpertRoutes { uint words[]; } expert_routes;
layout(set = 0, binding = 2) buffer ExpertOutputs { uint words[]; } expert_outputs;
layout(set = 0, binding = 3) readonly buffer ExpertOutputWeight { uint words[]; } expert_output_weight;
layout(set = 0, binding = 4) readonly buffer ExpertOutputScaleInv { uint words[]; } expert_output_scale_inv;

layout(push_constant) uniform BatchControl { uint batch_width; } batch_control;

const uint BLOCK_ROWS = {{BLOCK_ROWS}}u;
const uint BLOCK_COLUMNS = {{BLOCK_COLUMNS}}u;
const uint HIDDEN_SIZE = {{HIDDEN_SIZE}}u;
const uint INTERMEDIATE_SIZE = {{INTERMEDIATE_SIZE}}u;
const uint NUM_EXPERTS = {{NUM_EXPERTS}}u;
const uint EXPERTS_PER_TOKEN = {{EXPERTS_PER_TOKEN}}u;
const uint HIDDEN_WORDS = HIDDEN_SIZE / 2u;
const uint INTERMEDIATE_WORDS = INTERMEDIATE_SIZE / 2u;
const uint SCALE_ROWS = (HIDDEN_SIZE + BLOCK_ROWS - 1u) / BLOCK_ROWS;
const uint SCALE_COLUMNS = (INTERMEDIATE_SIZE + BLOCK_COLUMNS - 1u) / BLOCK_COLUMNS;

shared float subgroup_lo[64];
shared float subgroup_hi[64];

float bf16_to_f32(uint value) { return uintBitsToFloat((value & 0xffffu) << 16); }

uint f32_to_bf16(float value) {
    uint bits = floatBitsToUint(value);
    uint lsb = (bits >> 16) & 1u;
    return (bits + 0x7fffu + lsb) >> 16;
}

float round_bf16(float value) { return bf16_to_f32(f32_to_bf16(value)); }

float fp8_e4m3_to_f32(uint value) {
    return float(uintBitsToFloate4m3EXT(uint8_t(value & 0xffu)));
}

vec4 fp8_e4m3x4_to_f32(uint packed) {
    return vec4(
        fp8_e4m3_to_f32(packed),
        fp8_e4m3_to_f32(packed >> 8u),
        fp8_e4m3_to_f32(packed >> 16u),
        fp8_e4m3_to_f32(packed >> 24u)
    );
}

float read_bf16_word(uint packed, uint index) {
    return bf16_to_f32(packed >> ((index & 1u) * 16u));
}

float read_intermediate(uint batch_index, uint route, uint index) {
    uint base = (batch_index * EXPERTS_PER_TOKEN + route) * INTERMEDIATE_WORDS;
    return read_bf16_word(expert_intermediates.words[base + (index >> 1u)], index);
}

vec4 read_intermediatex4(uint batch_index, uint route, uint column) {
    uint offset = (batch_index * EXPERTS_PER_TOKEN + route) * INTERMEDIATE_WORDS
        + (column >> 1u);
    uint lo = expert_intermediates.words[offset];
    uint hi = expert_intermediates.words[offset + 1u];
    return vec4(
        bf16_to_f32(lo),
        bf16_to_f32(lo >> 16u),
        bf16_to_f32(hi),
        bf16_to_f32(hi >> 16u)
    );
}

float read_scale(uint expert, uint row, uint column) {
    uint index = (expert * SCALE_ROWS + row / BLOCK_ROWS)
        * SCALE_COLUMNS + column / BLOCK_COLUMNS;
    return read_bf16_word(expert_output_scale_inv.words[index >> 1u], index);
}

float read_weight(uint expert, uint row, uint column) {
    uint index = (expert * HIDDEN_SIZE + row) * INTERMEDIATE_SIZE + column;
    uint packed = expert_output_weight.words[index >> 2u];
    return fp8_e4m3_to_f32(packed >> ((index & 3u) * 8u));
}

vec4 read_weightx4(uint expert, uint row, uint column) {
    uint index = (expert * HIDDEN_SIZE + row) * INTERMEDIATE_SIZE + column;
    return fp8_e4m3x4_to_f32(expert_output_weight.words[index >> 2u]);
}

void main() {
    uint batch_index = gl_WorkGroupID.y;
    uint group = gl_WorkGroupID.x;
    uint route = group / HIDDEN_WORDS;
    uint word = group % HIDDEN_WORDS;
    if (batch_index >= batch_control.batch_width || route >= EXPERTS_PER_TOKEN) {
        return;
    }
    uint packed_route = expert_routes.words[
        batch_index * EXPERTS_PER_TOKEN + route
    ];
    uint expert = packed_route & 0xffffu;
    if (expert >= NUM_EXPERTS) {
        return;
    }
    float route_weight = bf16_to_f32(packed_route >> 16u);

    uint lane = gl_LocalInvocationID.x;
    uint lo_row = word * 2u;
    uint hi_row = lo_row + 1u;
    float lo = 0.0;
    float hi = 0.0;
    if ((INTERMEDIATE_SIZE % 4u) == 0u && (BLOCK_COLUMNS % 4u) == 0u) {
        for (uint column = lane * 4u; column < INTERMEDIATE_SIZE; column += 256u) {
            vec4 intermediate = read_intermediatex4(batch_index, route, column);
            lo = fma(dot(intermediate, read_weightx4(expert, lo_row, column)), read_scale(expert, lo_row, column), lo);
            hi = fma(dot(intermediate, read_weightx4(expert, hi_row, column)), read_scale(expert, hi_row, column), hi);
        }
    } else {
        for (uint column = lane; column < INTERMEDIATE_SIZE; column += 64u) {
            float intermediate = read_intermediate(batch_index, route, column);
            lo = fma(intermediate, read_weight(expert, lo_row, column) * read_scale(expert, lo_row, column), lo);
            hi = fma(intermediate, read_weight(expert, hi_row, column) * read_scale(expert, hi_row, column), hi);
        }
    }

    lo = subgroupAdd(lo);
    hi = subgroupAdd(hi);
    if (gl_NumSubgroups > 1u && gl_SubgroupInvocationID == 0u) {
        subgroup_lo[gl_SubgroupID] = lo;
        subgroup_hi[gl_SubgroupID] = hi;
    }
    barrier();
    if (lane == 0u) {
        if (gl_NumSubgroups > 1u) {
            lo = 0.0;
            hi = 0.0;
            for (uint subgroup = 0u; subgroup < gl_NumSubgroups; subgroup++) {
                lo += subgroup_lo[subgroup];
                hi += subgroup_hi[subgroup];
            }
        }
        lo = round_bf16(round_bf16(lo) * route_weight);
        hi = round_bf16(round_bf16(hi) * route_weight);
        uint output_offset = batch_index * EXPERTS_PER_TOKEN * HIDDEN_WORDS;
        expert_outputs.words[output_offset + route * HIDDEN_WORDS + word] =
            (f32_to_bf16(hi) << 16u) | f32_to_bf16(lo);
    }
}
