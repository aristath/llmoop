#version 460

#extension GL_KHR_shader_subgroup_basic : require
#extension GL_KHR_shader_subgroup_arithmetic : require
#extension GL_KHR_shader_subgroup_clustered : require
#extension GL_EXT_shader_explicit_arithmetic_types_int8 : require
#extension GL_EXT_float_e4m3 : require
#extension GL_EXT_spirv_intrinsics : require

spirv_instruction(
    extensions = ["SPV_VALVE_mixed_float_dot_product"],
    capabilities = [6915],
    id = 6918
)
float fp8_dot4_acc32(fe4m3vec4 a, fe4m3vec4 b, float accumulator);

layout(local_size_x = 64, local_size_y = 1, local_size_z = 1) in;

layout(set = 0, binding = 0) readonly buffer ExpertIntermediates { uint words[]; } expert_intermediates;
layout(set = 0, binding = 1) readonly buffer ExpertRoutes { uint words[]; } expert_routes;
layout(set = 0, binding = 2) buffer ExpertOutputs { uint words[]; } expert_outputs;
layout(set = 0, binding = 3) readonly buffer ExpertOutputWeight { uint words[]; } expert_output_weight;
layout(set = 0, binding = 4) readonly buffer ExpertOutputScaleInv { uint words[]; } expert_output_scale_inv;

layout(push_constant) uniform BatchControl { uint batch_width; } batch_control;

const uint BLOCK_ROWS = {{BLOCK_ROWS}}u;
const uint BLOCK_COLUMNS = {{BLOCK_COLUMNS}}u;
const uint HIDDEN_SIZE = {{HIDDEN_SIZE}}u;
const uint INTERMEDIATE_SIZE = {{INTERMEDIATE_SIZE}}u;
const uint NUM_EXPERTS = {{NUM_EXPERTS}}u;
const uint EXPERTS_PER_TOKEN = {{EXPERTS_PER_TOKEN}}u;
const uint TILE_ROWS = {{TILE_ROWS}}u;
const uint TILES_PER_ROUTE = (HIDDEN_SIZE + TILE_ROWS - 1u) / TILE_ROWS;
const uint HIDDEN_WORDS = HIDDEN_SIZE / 2u;
const uint INTERMEDIATE_WORDS = INTERMEDIATE_SIZE / 2u;
const uint INTERMEDIATE_FP8_WORDS = INTERMEDIATE_SIZE / 4u;
const uint INTERMEDIATE_BLOCKS = INTERMEDIATE_SIZE / BLOCK_COLUMNS;
const uint BLOCK_FP8_WORDS = BLOCK_COLUMNS / 4u;
const uint EXPERT_OUTPUT_WORDS = HIDDEN_SIZE * INTERMEDIATE_SIZE / 4u;
const uint SCALE_ROWS = (HIDDEN_SIZE + BLOCK_ROWS - 1u) / BLOCK_ROWS;
const uint SCALE_COLUMNS = INTERMEDIATE_BLOCKS;

shared fe4m3vec4 quantized_intermediate[INTERMEDIATE_FP8_WORDS];
shared float intermediate_scales[INTERMEDIATE_BLOCKS];
shared float subgroup_sum[TILE_ROWS][64];
shared float output_rows[TILE_ROWS];

float bf16_to_f32(uint value) { return uintBitsToFloat((value & 0xffffu) << 16); }

uint f32_to_bf16(float value) {
    uint bits = floatBitsToUint(value);
    uint lsb = (bits >> 16) & 1u;
    return (bits + 0x7fffu + lsb) >> 16;
}

float round_bf16(float value) { return bf16_to_f32(f32_to_bf16(value)); }

float read_bf16_word(uint packed, uint index) {
    return bf16_to_f32(packed >> ((index & 1u) * 16u));
}

vec4 read_intermediatex4(uint batch_index, uint route, uint column) {
    uint offset = (batch_index * EXPERTS_PER_TOKEN + route) * INTERMEDIATE_WORDS
        + (column >> 1u);
    uint lo = expert_intermediates.words[offset];
    uint hi = expert_intermediates.words[offset + 1u];
    return vec4(
        bf16_to_f32(lo),
        bf16_to_f32(lo >> 16u),
        bf16_to_f32(hi),
        bf16_to_f32(hi >> 16u)
    );
}

float read_scale(uint expert, uint row, uint block) {
    uint index = (expert * SCALE_ROWS + row / BLOCK_ROWS) * SCALE_COLUMNS + block;
    return read_bf16_word(expert_output_scale_inv.words[index >> 1u], index);
}

fe4m3vec4 read_weightx4(uint expert, uint row, uint column) {
    uint index = (expert * HIDDEN_SIZE + row) * INTERMEDIATE_SIZE + column;
    uint packed = expert_output_weight.words[index >> 2u];
    return uintBitsToFloate4m3EXT(u8vec4(
        uint8_t(packed),
        uint8_t(packed >> 8u),
        uint8_t(packed >> 16u),
        uint8_t(packed >> 24u)
    ));
}

void main() {
    uint batch_index = gl_WorkGroupID.y;
    uint group = gl_WorkGroupID.x;
    uint route = group / TILES_PER_ROUTE;
    uint tile = group % TILES_PER_ROUTE;
    if (batch_index >= batch_control.batch_width || route >= EXPERTS_PER_TOKEN) {
        return;
    }
    uint route_offset = batch_index * EXPERTS_PER_TOKEN;
    uint packed_route = expert_routes.words[route_offset + route];
    uint expert = packed_route & 0xffffu;
    if (expert >= NUM_EXPERTS) {
        return;
    }
    uint expert_start = gl_WorkGroupID.z;
    uint expert_count = expert_output_weight.words.length() / EXPERT_OUTPUT_WORDS;
    if (expert < expert_start || expert >= expert_start + expert_count) {
        return;
    }
    expert -= expert_start;
    float route_weight = bf16_to_f32(packed_route >> 16u);

    uint lane = gl_LocalInvocationID.x;
    uint cluster = lane >> 5u;
    uint cluster_lane = lane & 31u;
    for (uint block = cluster; block < INTERMEDIATE_BLOCKS; block += 2u) {
        uint word = block * BLOCK_FP8_WORDS + cluster_lane;
        vec4 intermediate = read_intermediatex4(batch_index, route, word * 4u);
        float lane_max = max(
            max(abs(intermediate.x), abs(intermediate.y)),
            max(abs(intermediate.z), abs(intermediate.w))
        );
        float block_max = subgroupClusteredMax(lane_max, 32u);
        float scale = block_max > 0.0 ? block_max / 448.0 : 1.0;
        if (cluster_lane == 0u) {
            intermediate_scales[block] = scale;
        }
        quantized_intermediate[word] = fe4m3vec4(intermediate / scale);
    }
    barrier();

    uint first_row = tile * TILE_ROWS;
    for (uint local_row = 0u; local_row < TILE_ROWS; local_row++) {
        uint row = first_row + local_row;
        float sum = 0.0;
        if (row < HIDDEN_SIZE) {
            for (uint word = lane; word < INTERMEDIATE_FP8_WORDS; word += 64u) {
                uint block = word / BLOCK_FP8_WORDS;
                sum = fma(
                    fp8_dot4_acc32(
                        quantized_intermediate[word],
                        read_weightx4(expert, row, word * 4u),
                        0.0
                    ),
                    intermediate_scales[block] * read_scale(expert, row, block),
                    sum
                );
            }
        }
        sum = subgroupAdd(sum);
        if (gl_SubgroupInvocationID == 0u) {
            subgroup_sum[local_row][gl_SubgroupID] = sum;
        }
    }
    barrier();

    if (lane < TILE_ROWS) {
        uint row = first_row + lane;
        float sum = 0.0;
        for (uint subgroup = 0u; subgroup < gl_NumSubgroups; subgroup++) {
            sum += subgroup_sum[lane][subgroup];
        }
        output_rows[lane] = row < HIDDEN_SIZE
            ? round_bf16(round_bf16(sum) * route_weight)
            : 0.0;
    }
    barrier();

    if (lane < TILE_ROWS / 2u) {
        uint row = first_row + lane * 2u;
        if (row < HIDDEN_SIZE) {
            uint hi = row + 1u < HIDDEN_SIZE
                ? f32_to_bf16(output_rows[lane * 2u + 1u])
                : 0u;
            uint output_offset = batch_index * EXPERTS_PER_TOKEN * HIDDEN_WORDS;
            expert_outputs.words[output_offset + route * HIDDEN_WORDS + row / 2u] =
                (hi << 16u) | f32_to_bf16(output_rows[lane * 2u]);
        }
    }
}
