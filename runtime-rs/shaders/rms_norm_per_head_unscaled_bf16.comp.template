#version 450

#extension GL_KHR_shader_subgroup_basic : require
#extension GL_KHR_shader_subgroup_arithmetic : require

layout(local_size_x = 64, local_size_y = 1, local_size_z = 1) in;

layout(set = 0, binding = 0) readonly buffer InputFrame { uint words[]; } input_frame;
layout(set = 0, binding = 1) buffer OutputFrame { uint words[]; } output_frame;

const uint HEAD_COUNT = {{HEAD_COUNT}}u;
const uint HEAD_WIDTH = {{HEAD_WIDTH}}u;
const float NORM_EPS = {{NORM_EPS}};

shared float reduction[64];

float bf16_to_f32(uint value) { return uintBitsToFloat((value & 0xffffu) << 16); }
uint f32_to_bf16(float value) {
    uint bits = floatBitsToUint(value);
    uint lsb = (bits >> 16) & 1u;
    return (bits + 0x7fffu + lsb) >> 16;
}
float read_input(uint index) {
    uint packed = input_frame.words[index >> 1];
    return bf16_to_f32(((index & 1u) == 0u) ? packed : (packed >> 16));
}

void main() {
    uint head = gl_WorkGroupID.x;
    uint lane = gl_LocalInvocationID.x;
    if (head >= HEAD_COUNT) { return; }
    uint base = head * HEAD_WIDTH;
    float sum_squares = 0.0;
    for (uint dim = lane; dim < HEAD_WIDTH; dim += 64u) {
        float value = read_input(base + dim);
        sum_squares = fma(value, value, sum_squares);
    }
    sum_squares = subgroupAdd(sum_squares);
    if (gl_SubgroupInvocationID == 0u) { reduction[gl_SubgroupID] = sum_squares; }
    barrier();
    sum_squares = 0.0;
    for (uint subgroup = 0u; subgroup < gl_NumSubgroups; subgroup++) {
        sum_squares += reduction[subgroup];
    }
    float inv_rms = inversesqrt((sum_squares / float(HEAD_WIDTH)) + NORM_EPS);
    for (uint dim = lane * 2u; dim < HEAD_WIDTH; dim += 128u) {
        uint lo = f32_to_bf16(read_input(base + dim) * inv_rms);
        uint hi = f32_to_bf16(read_input(base + dim + 1u) * inv_rms);
        output_frame.words[(base + dim) >> 1] = (hi << 16) | lo;
    }
}
