#version 450

#extension GL_KHR_shader_subgroup_basic : require
#extension GL_KHR_shader_subgroup_arithmetic : require

layout(local_size_x = 64, local_size_y = 1, local_size_z = 1) in;

layout(set = 0, binding = 0) readonly buffer InputFrame {
    uint words[];
} input_frame;

layout(set = 0, binding = 1) buffer OutputFrame {
    uint words[];
} output_frame;

layout(set = 0, binding = 2) readonly buffer Weight {
    uint words[];
} weight;

const uint HIDDEN_SIZE = {{HIDDEN_SIZE}}u;
const float NORM_EPS = {{NORM_EPS}};
const float WEIGHT_OFFSET = {{WEIGHT_OFFSET}};

shared float reduction[64];

float bf16_to_f32(uint value) {
    return uintBitsToFloat((value & 0xffffu) << 16);
}

uint f32_to_bf16(float value) {
    uint bits = floatBitsToUint(value);
    uint lsb = (bits >> 16) & 1u;
    uint rounding_bias = 0x7fffu + lsb;
    return (bits + rounding_bias) >> 16;
}

float read_input(uint index) {
    uint packed = input_frame.words[index >> 1];
    uint value = ((index & 1u) == 0u) ? (packed & 0xffffu) : (packed >> 16);
    return bf16_to_f32(value);
}

float read_weight(uint index) {
    uint packed = weight.words[index >> 1];
    uint value = ((index & 1u) == 0u) ? (packed & 0xffffu) : (packed >> 16);
    return bf16_to_f32(value);
}

void main() {
    uint lane = gl_LocalInvocationID.x;
    float sum_squares = 0.0;
    for (uint index = lane; index < HIDDEN_SIZE; index += 64u) {
        float value = read_input(index);
        sum_squares = fma(value, value, sum_squares);
    }
    sum_squares = subgroupAdd(sum_squares);
    if (gl_SubgroupInvocationID == 0u) {
        reduction[gl_SubgroupID] = sum_squares;
    }
    barrier();
    sum_squares = 0.0;
    for (uint subgroup = 0u; subgroup < gl_NumSubgroups; subgroup++) {
        sum_squares += reduction[subgroup];
    }
    float inv_rms = inversesqrt((sum_squares / float(HIDDEN_SIZE)) + NORM_EPS);

    for (uint index = lane * 2u; index < HIDDEN_SIZE; index += 128u) {
        float lo = read_input(index) * inv_rms * (read_weight(index) + WEIGHT_OFFSET);
        float hi = read_input(index + 1u) * inv_rms * (read_weight(index + 1u) + WEIGHT_OFFSET);
        output_frame.words[index >> 1] = (f32_to_bf16(hi) << 16) | f32_to_bf16(lo);
    }
}
