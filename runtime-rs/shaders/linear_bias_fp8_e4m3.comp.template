#version 450

#extension GL_KHR_shader_subgroup_basic : require
#extension GL_KHR_shader_subgroup_arithmetic : require

layout(local_size_x = 64, local_size_y = 1, local_size_z = 1) in;

layout(set = 0, binding = 0) readonly buffer InputFrame { uint words[]; } input_frame;
layout(set = 0, binding = 1) buffer OutputFrame { uint words[]; } output_frame;
layout(set = 0, binding = 2) readonly buffer Weight { uint words[]; } weight;
layout(set = 0, binding = 3) readonly buffer WeightScaleInv { uint words[]; } weight_scale_inv;
layout(set = 0, binding = 4) readonly buffer Bias { uint words[]; } bias;

const uint BLOCK_ROWS = {{BLOCK_ROWS}}u;
const uint BLOCK_COLUMNS = {{BLOCK_COLUMNS}}u;
const uint INPUT_SIZE = {{INPUT_SIZE}}u;
const uint OUTPUT_SIZE = {{OUTPUT_SIZE}}u;
const uint OUTPUT_WORDS = (OUTPUT_SIZE + 1u) / 2u;
const uint SCALE_COLUMNS = (INPUT_SIZE + BLOCK_COLUMNS - 1u) / BLOCK_COLUMNS;

shared float subgroup_lo[64];
shared float subgroup_hi[64];

float bf16_to_f32(uint value) { return uintBitsToFloat((value & 0xffffu) << 16); }

float read_input_bf16(uint index) {
    uint pair = input_frame.words[index >> 1u];
    return bf16_to_f32(pair >> ((index & 1u) * 16u));
}

float read_scale_bf16(uint index) {
    uint pair = weight_scale_inv.words[index >> 1u];
    return bf16_to_f32(pair >> ((index & 1u) * 16u));
}

float read_bias_bf16(uint index) {
    uint pair = bias.words[index >> 1u];
    return bf16_to_f32(pair >> ((index & 1u) * 16u));
}

float fp8_e4m3_to_f32(uint value) {
    uint bits = value & 0xffu;
    uint exponent = (bits >> 3u) & 0x0fu;
    uint mantissa = bits & 0x07u;
    if (exponent == 0u) {
        float subnormal = float(mantissa) * 0.001953125;
        return (bits & 0x80u) != 0u ? -subnormal : subnormal;
    }
    return uintBitsToFloat(
        ((bits & 0x80u) << 24u)
        | ((exponent + 120u) << 23u)
        | (mantissa << 20u)
    );
}

float read_weight(uint row, uint column) {
    uint index = row * INPUT_SIZE + column;
    uint packed = weight.words[index >> 2u];
    float value = fp8_e4m3_to_f32(packed >> ((index & 3u) * 8u));
    uint scale_index = (row / BLOCK_ROWS) * SCALE_COLUMNS + column / BLOCK_COLUMNS;
    return value * read_scale_bf16(scale_index);
}

uint f32_to_bf16(float value) {
    uint bits = floatBitsToUint(value);
    uint lsb = (bits >> 16) & 1u;
    return (bits + 0x7fffu + lsb) >> 16;
}

void main() {
    uint word_index = gl_WorkGroupID.x;
    uint lane = gl_LocalInvocationID.x;
    uint lo_row = word_index * 2u;
    uint hi_row = lo_row + 1u;
    float lo_sum = 0.0;
    float hi_sum = 0.0;

    if (word_index < OUTPUT_WORDS) {
        for (uint column = lane; column < INPUT_SIZE; column += 64u) {
            float input_value = read_input_bf16(column);
            lo_sum = fma(input_value, read_weight(lo_row, column), lo_sum);
            if (hi_row < OUTPUT_SIZE) {
                hi_sum = fma(input_value, read_weight(hi_row, column), hi_sum);
            }
        }
    }

    lo_sum = subgroupAdd(lo_sum);
    hi_sum = subgroupAdd(hi_sum);
    if (gl_SubgroupInvocationID == 0u) {
        subgroup_lo[gl_SubgroupID] = lo_sum;
        subgroup_hi[gl_SubgroupID] = hi_sum;
    }
    barrier();

    if (lane == 0u && word_index < OUTPUT_WORDS) {
        float lo_total = read_bias_bf16(lo_row);
        float hi_total = hi_row < OUTPUT_SIZE ? read_bias_bf16(hi_row) : 0.0;
        for (uint subgroup = 0u; subgroup < gl_NumSubgroups; subgroup++) {
            lo_total += subgroup_lo[subgroup];
            hi_total += subgroup_hi[subgroup];
        }
        uint lo = f32_to_bf16(lo_total);
        uint hi = hi_row < OUTPUT_SIZE ? f32_to_bf16(hi_total) : 0u;
        output_frame.words[word_index] = (hi << 16u) | lo;
    }
}
