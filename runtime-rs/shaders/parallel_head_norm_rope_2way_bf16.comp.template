#version 450

#extension GL_KHR_shader_subgroup_basic : require
#extension GL_KHR_shader_subgroup_arithmetic : require

layout(local_size_x = 64, local_size_y = 1, local_size_z = 1) in;

layout(set = 0, binding = 0) readonly buffer InputA {
    uint words[];
} input_a;

layout(set = 0, binding = 1) readonly buffer InputB {
    uint words[];
} input_b;

layout(set = 0, binding = 2) buffer OutputA {
    uint words[];
} output_a;

layout(set = 0, binding = 3) buffer OutputB {
    uint words[];
} output_b;

layout(set = 0, binding = 4) readonly buffer WeightA {
    uint words[];
} weight_a;

layout(set = 0, binding = 5) readonly buffer WeightB {
    uint words[];
} weight_b;

layout(set = 0, binding = 6) readonly buffer StreamControl {
    uint words[];
} stream_control;

const uint BRANCH_A_HEADS = {{BRANCH_A_HEADS}}u;
const uint BRANCH_B_HEADS = {{BRANCH_B_HEADS}}u;
const uint HEAD_WIDTH = {{HEAD_WIDTH}}u;
const uint ROTARY_WIDTH = {{ROTARY_WIDTH}}u;
const float NORM_EPS = {{NORM_EPS}};
const float WEIGHT_OFFSET = {{WEIGHT_OFFSET}};
const float ROPE_THETA = {{ROPE_THETA}};
const bool ROPE_INTERLEAVED = {{ROPE_INTERLEAVED}};
const bool ROPE_PROPORTIONAL = {{ROPE_PROPORTIONAL}};
const bool ROPE_YARN = {{ROPE_YARN}};
const float ROPE_FACTOR = {{ROPE_FACTOR}};
const float ROPE_CORRECTION_LOW = {{ROPE_CORRECTION_LOW}};
const float ROPE_CORRECTION_HIGH = {{ROPE_CORRECTION_HIGH}};
const float ROPE_ATTENTION_FACTOR = {{ROPE_ATTENTION_FACTOR}};

shared float reduction[64];
shared uint normalized_words[(HEAD_WIDTH + 1u) / 2u];

float bf16_to_f32(uint value) {
    return uintBitsToFloat((value & 0xffffu) << 16);
}

uint f32_to_bf16(float value) {
    uint bits = floatBitsToUint(value);
    uint lsb = (bits >> 16) & 1u;
    uint rounding_bias = 0x7fffu + lsb;
    return (bits + rounding_bias) >> 16;
}

float round_bf16(float value) {
    return bf16_to_f32(f32_to_bf16(value));
}

float read_branch_input(uint branch, uint index) {
    uint packed = branch == 0u
        ? input_a.words[index >> 1]
        : input_b.words[index >> 1];
    uint value = ((index & 1u) == 0u) ? (packed & 0xffffu) : (packed >> 16);
    return bf16_to_f32(value);
}

float read_branch_weight(uint branch, uint index) {
    uint packed = branch == 0u
        ? weight_a.words[index >> 1]
        : weight_b.words[index >> 1];
    uint value = ((index & 1u) == 0u) ? (packed & 0xffffu) : (packed >> 16);
    return bf16_to_f32(value);
}

float read_normalized(uint dim) {
    uint packed = normalized_words[dim >> 1];
    uint value = ((dim & 1u) == 0u) ? (packed & 0xffffu) : (packed >> 16);
    return bf16_to_f32(value);
}

float rotate_value(uint dim) {
    if (ROPE_PROPORTIONAL) {
        uint half_width = HEAD_WIDTH / 2u;
        return dim < half_width
            ? -read_normalized(dim + half_width)
            : read_normalized(dim - half_width);
    }
    if (ROPE_INTERLEAVED) {
        return (dim & 1u) == 0u
            ? -read_normalized(dim + 1u)
            : read_normalized(dim - 1u);
    }
    return dim < (ROTARY_WIDTH / 2u)
        ? -read_normalized(dim + (ROTARY_WIDTH / 2u))
        : read_normalized(dim - (ROTARY_WIDTH / 2u));
}

float rope_inverse_frequency(uint frequency_index, uint frequency_width) {
    float inverse_frequency = pow(
        ROPE_THETA,
        -2.0 * float(frequency_index) / float(frequency_width)
    );
    if (!ROPE_YARN) return inverse_frequency;
    float ramp = clamp(
        (float(frequency_index) - ROPE_CORRECTION_LOW)
            / (ROPE_CORRECTION_HIGH - ROPE_CORRECTION_LOW),
        0.0,
        1.0
    );
    return mix(inverse_frequency, inverse_frequency / ROPE_FACTOR, ramp);
}

float rope_angle(uint dim) {
    if (ROPE_PROPORTIONAL) {
        uint half_width = HEAD_WIDTH / 2u;
        uint frequency_index = dim % half_width;
        if (frequency_index >= (ROTARY_WIDTH / 2u)) {
            return 0.0;
        }
        float inv_freq = rope_inverse_frequency(frequency_index, HEAD_WIDTH);
        return float(stream_control.words[1]) * inv_freq;
    }
    uint frequency_index = ROPE_INTERLEAVED
        ? dim / 2u
        : dim % (ROTARY_WIDTH / 2u);
    float inv_freq = rope_inverse_frequency(frequency_index, ROTARY_WIDTH);
    return float(stream_control.words[1]) * inv_freq;
}

float rotate(uint dim) {
    if (!ROPE_PROPORTIONAL && dim >= ROTARY_WIDTH) {
        return read_normalized(dim);
    }
    float angle = rope_angle(dim);
    float cosine = round_bf16(cos(angle) * ROPE_ATTENTION_FACTOR);
    float sine = round_bf16(sin(angle) * ROPE_ATTENTION_FACTOR);
    float direct = round_bf16(read_normalized(dim) * cosine);
    float rotated = round_bf16(rotate_value(dim) * sine);
    return round_bf16(direct + rotated);
}

void write_branch_output(uint branch, uint word_index, uint packed) {
    if (branch == 0u) {
        output_a.words[word_index] = packed;
    } else {
        output_b.words[word_index] = packed;
    }
}

void main() {
    uint global_head = gl_WorkGroupID.x;
    uint lane = gl_LocalInvocationID.x;
    uint total_heads = BRANCH_A_HEADS + BRANCH_B_HEADS;
    if (global_head >= total_heads) {
        return;
    }

    uint branch = global_head < BRANCH_A_HEADS ? 0u : 1u;
    uint head = branch == 0u ? global_head : global_head - BRANCH_A_HEADS;
    uint base = head * HEAD_WIDTH;

    float sum_squares = 0.0;
    for (uint dim = lane; dim < HEAD_WIDTH; dim += 64u) {
        float value = read_branch_input(branch, base + dim);
        sum_squares = fma(value, value, sum_squares);
    }
    sum_squares = subgroupAdd(sum_squares);
    if (gl_SubgroupInvocationID == 0u) {
        reduction[gl_SubgroupID] = sum_squares;
    }
    barrier();
    sum_squares = 0.0;
    for (uint subgroup = 0u; subgroup < gl_NumSubgroups; subgroup++) {
        sum_squares += reduction[subgroup];
    }
    float inv_rms = inversesqrt((sum_squares / float(HEAD_WIDTH)) + NORM_EPS);

    for (uint pair_dim = lane * 2u; pair_dim < HEAD_WIDTH; pair_dim += 128u) {
        float lo = read_branch_input(branch, base + pair_dim)
            * inv_rms
            * (read_branch_weight(branch, pair_dim) + WEIGHT_OFFSET);
        float hi = read_branch_input(branch, base + pair_dim + 1u)
            * inv_rms
            * (read_branch_weight(branch, pair_dim + 1u) + WEIGHT_OFFSET);
        normalized_words[pair_dim >> 1] =
            (f32_to_bf16(hi) << 16) | f32_to_bf16(lo);
    }
    barrier();

    for (uint dim = lane * 2u; dim < HEAD_WIDTH; dim += 128u) {
        float lo = rotate(dim);
        float hi = rotate(dim + 1u);
        write_branch_output(
            branch,
            (base + dim) >> 1,
            (f32_to_bf16(hi) << 16) | f32_to_bf16(lo)
        );
    }
}
