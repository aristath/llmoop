#version 450

layout(local_size_x = 256, local_size_y = 1, local_size_z = 1) in;

layout(set = 0, binding = 0) readonly buffer HiddenInput { uint words[]; } hidden_input;
layout(set = 0, binding = 1) readonly buffer RoutingWeights { uint words[]; } routing_weights;
layout(set = 0, binding = 2) buffer ExpertOutputs { uint words[]; } expert_outputs;
layout(set = 0, binding = 3) readonly buffer ExpertInputWeight { uint words[]; } expert_input_weight;
layout(set = 0, binding = 4) readonly buffer ExpertInputScaleInv { uint words[]; } expert_input_scale_inv;
layout(set = 0, binding = 5) readonly buffer ExpertOutputWeight { uint words[]; } expert_output_weight;
layout(set = 0, binding = 6) readonly buffer ExpertOutputScaleInv { uint words[]; } expert_output_scale_inv;

const uint BLOCK_ROWS = {{BLOCK_ROWS}}u;
const uint BLOCK_COLUMNS = {{BLOCK_COLUMNS}}u;
const uint HIDDEN_SIZE = {{HIDDEN_SIZE}}u;
const uint INTERMEDIATE_SIZE = {{INTERMEDIATE_SIZE}}u;
const uint NUM_EXPERTS = {{NUM_EXPERTS}}u;
const uint EXPERTS_PER_TOKEN = {{EXPERTS_PER_TOKEN}}u;
const uint HIDDEN_WORDS = HIDDEN_SIZE / 2u;
const uint INTERMEDIATE_WORDS = INTERMEDIATE_SIZE / 2u;
const uint EXPERT_INPUT_ROWS = INTERMEDIATE_SIZE * 2u;
const uint INPUT_SCALE_ROWS = (EXPERT_INPUT_ROWS + BLOCK_ROWS - 1u) / BLOCK_ROWS;
const uint INPUT_SCALE_COLUMNS = (HIDDEN_SIZE + BLOCK_COLUMNS - 1u) / BLOCK_COLUMNS;
const uint OUTPUT_SCALE_ROWS = (HIDDEN_SIZE + BLOCK_ROWS - 1u) / BLOCK_ROWS;
const uint OUTPUT_SCALE_COLUMNS = (INTERMEDIATE_SIZE + BLOCK_COLUMNS - 1u) / BLOCK_COLUMNS;

shared uint intermediate_words[INTERMEDIATE_WORDS];

float bf16_to_f32(uint value) { return uintBitsToFloat((value & 0xffffu) << 16); }

uint f32_to_bf16(float value) {
    uint bits = floatBitsToUint(value);
    uint lsb = (bits >> 16) & 1u;
    return (bits + 0x7fffu + lsb) >> 16;
}

float round_bf16(float value) { return bf16_to_f32(f32_to_bf16(value)); }

float fp8_e4m3_to_f32(uint value) {
    uint bits = value & 0xffu;
    uint exponent = (bits >> 3u) & 0x0fu;
    uint mantissa = bits & 0x07u;
    if (exponent == 0u) {
        float subnormal = float(mantissa) * 0.001953125;
        return (bits & 0x80u) != 0u ? -subnormal : subnormal;
    }
    return uintBitsToFloat(
        ((bits & 0x80u) << 24u)
        | ((exponent + 120u) << 23u)
        | (mantissa << 20u)
    );
}

float read_bf16_word(uint packed, uint index) {
    return bf16_to_f32(packed >> ((index & 1u) * 16u));
}

float read_hidden(uint index) {
    return read_bf16_word(hidden_input.words[index >> 1u], index);
}

float read_route(uint expert) {
    return read_bf16_word(routing_weights.words[expert >> 1u], expert);
}

float read_intermediate(uint index) {
    return read_bf16_word(intermediate_words[index >> 1u], index);
}

float read_input_scale(uint expert, uint row, uint column) {
    uint index = (expert * INPUT_SCALE_ROWS + row / BLOCK_ROWS)
        * INPUT_SCALE_COLUMNS + column / BLOCK_COLUMNS;
    return read_bf16_word(expert_input_scale_inv.words[index >> 1u], index);
}

float read_output_scale(uint expert, uint row, uint column) {
    uint index = (expert * OUTPUT_SCALE_ROWS + row / BLOCK_ROWS)
        * OUTPUT_SCALE_COLUMNS + column / BLOCK_COLUMNS;
    return read_bf16_word(expert_output_scale_inv.words[index >> 1u], index);
}

float read_expert_input(uint expert, uint row, uint column) {
    uint index = (expert * EXPERT_INPUT_ROWS + row) * HIDDEN_SIZE + column;
    uint packed = expert_input_weight.words[index >> 2u];
    float value = fp8_e4m3_to_f32(packed >> ((index & 3u) * 8u));
    return value * read_input_scale(expert, row, column);
}

float read_expert_output(uint expert, uint row, uint column) {
    uint index = (expert * HIDDEN_SIZE + row) * INTERMEDIATE_SIZE + column;
    uint packed = expert_output_weight.words[index >> 2u];
    float value = fp8_e4m3_to_f32(packed >> ((index & 3u) * 8u));
    return value * read_output_scale(expert, row, column);
}

float expert_input_linear(uint expert, uint row) {
    float sum = 0.0;
    for (uint column = 0u; column < HIDDEN_SIZE; column++) {
        sum = fma(read_hidden(column), read_expert_input(expert, row, column), sum);
    }
    return round_bf16(sum);
}

float expert_output_linear(uint expert, uint row) {
    float sum = 0.0;
    for (uint column = 0u; column < INTERMEDIATE_SIZE; column++) {
        sum = fma(read_intermediate(column), read_expert_output(expert, row, column), sum);
    }
    return round_bf16(sum);
}

void main() {
    uint expert = gl_WorkGroupID.x;
    uint lane = gl_LocalInvocationID.x;
    if (expert >= NUM_EXPERTS) {
        return;
    }
    float route_weight = read_route(expert);
    uint output_base = expert * HIDDEN_WORDS;
    if (route_weight == 0.0) {
        for (uint word = lane; word < HIDDEN_WORDS; word += 256u) {
            expert_outputs.words[output_base + word] = 0u;
        }
        return;
    }

    for (uint word = lane; word < INTERMEDIATE_WORDS; word += 256u) {
        uint first = word * 2u;
        float gate_lo = expert_input_linear(expert, first);
        float gate_hi = expert_input_linear(expert, first + 1u);
        float up_lo = expert_input_linear(expert, INTERMEDIATE_SIZE + first);
        float up_hi = expert_input_linear(expert, INTERMEDIATE_SIZE + first + 1u);
        float hidden_lo = round_bf16(
            round_bf16(gate_lo / (1.0 + exp(-gate_lo))) * up_lo
        );
        float hidden_hi = round_bf16(
            round_bf16(gate_hi / (1.0 + exp(-gate_hi))) * up_hi
        );
        intermediate_words[word] =
            (f32_to_bf16(hidden_hi) << 16u) | f32_to_bf16(hidden_lo);
    }
    barrier();

    for (uint word = lane; word < HIDDEN_WORDS; word += 256u) {
        uint first = word * 2u;
        float lo = round_bf16(expert_output_linear(expert, first) * route_weight);
        float hi = round_bf16(expert_output_linear(expert, first + 1u) * route_weight);
        expert_outputs.words[output_base + word] =
            (f32_to_bf16(hi) << 16u) | f32_to_bf16(lo);
    }
}
