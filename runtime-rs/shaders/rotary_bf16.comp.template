#version 450

layout(local_size_x = 64, local_size_y = 1, local_size_z = 1) in;

layout(set = 0, binding = 0) readonly buffer InputFrame {
    uint words[];
} input_frame;

layout(set = 0, binding = 1) buffer OutputFrame {
    uint words[];
} output_frame;

layout(set = 0, binding = 2) readonly buffer StreamControl {
    uint words[];
} stream_control;

const uint HEAD_COUNT = {{HEAD_COUNT}}u;
const uint HEAD_WIDTH = {{HEAD_WIDTH}}u;
const uint ROTARY_WIDTH = {{ROTARY_WIDTH}}u;
const float ROPE_THETA = {{ROPE_THETA}};
const bool ROPE_INTERLEAVED = {{ROPE_INTERLEAVED}};
const bool ROPE_PROPORTIONAL = {{ROPE_PROPORTIONAL}};
const bool ROPE_YARN = {{ROPE_YARN}};
const float ROPE_FACTOR = {{ROPE_FACTOR}};
const float ROPE_CORRECTION_LOW = {{ROPE_CORRECTION_LOW}};
const float ROPE_CORRECTION_HIGH = {{ROPE_CORRECTION_HIGH}};
const float ROPE_ATTENTION_FACTOR = {{ROPE_ATTENTION_FACTOR}};

float bf16_to_f32(uint value) {
    return uintBitsToFloat((value & 0xffffu) << 16);
}

uint f32_to_bf16(float value) {
    uint bits = floatBitsToUint(value);
    uint lsb = (bits >> 16) & 1u;
    uint rounding_bias = 0x7fffu + lsb;
    return (bits + rounding_bias) >> 16;
}

float round_bf16(float value) {
    return bf16_to_f32(f32_to_bf16(value));
}

float read_input(uint index) {
    uint packed = input_frame.words[index >> 1];
    uint value = ((index & 1u) == 0u) ? (packed & 0xffffu) : (packed >> 16);
    return bf16_to_f32(value);
}

float rotate_value(uint base, uint dim) {
    if (ROPE_PROPORTIONAL) {
        uint half_width = HEAD_WIDTH / 2u;
        return dim < half_width
            ? -read_input(base + dim + half_width)
            : read_input(base + dim - half_width);
    }
    if (ROPE_INTERLEAVED) {
        return (dim & 1u) == 0u
            ? -read_input(base + dim + 1u)
            : read_input(base + dim - 1u);
    }
    return dim < (ROTARY_WIDTH / 2u)
        ? -read_input(base + dim + (ROTARY_WIDTH / 2u))
        : read_input(base + dim - (ROTARY_WIDTH / 2u));
}

float rope_inverse_frequency(uint frequency_index, uint frequency_width) {
    float inverse_frequency = pow(
        ROPE_THETA,
        -2.0 * float(frequency_index) / float(frequency_width)
    );
    if (!ROPE_YARN) return inverse_frequency;
    float ramp = clamp(
        (float(frequency_index) - ROPE_CORRECTION_LOW)
            / (ROPE_CORRECTION_HIGH - ROPE_CORRECTION_LOW),
        0.0,
        1.0
    );
    return mix(inverse_frequency, inverse_frequency / ROPE_FACTOR, ramp);
}

float rope_angle(uint dim) {
    if (ROPE_PROPORTIONAL) {
        uint half_width = HEAD_WIDTH / 2u;
        uint frequency_index = dim % half_width;
        if (frequency_index >= (ROTARY_WIDTH / 2u)) {
            return 0.0;
        }
        float inv_freq = rope_inverse_frequency(frequency_index, HEAD_WIDTH);
        return float(stream_control.words[1]) * inv_freq;
    }
    uint frequency_index = ROPE_INTERLEAVED
        ? dim / 2u
        : dim % (ROTARY_WIDTH / 2u);
    float inv_freq = rope_inverse_frequency(frequency_index, ROTARY_WIDTH);
    return float(stream_control.words[1]) * inv_freq;
}

float rotate(uint base, uint dim) {
    if (!ROPE_PROPORTIONAL && dim >= ROTARY_WIDTH) {
        return read_input(base + dim);
    }
    float angle = rope_angle(dim);
    float cosine = round_bf16(cos(angle) * ROPE_ATTENTION_FACTOR);
    float sine = round_bf16(sin(angle) * ROPE_ATTENTION_FACTOR);
    float direct = round_bf16(read_input(base + dim) * cosine);
    float rotated = round_bf16(rotate_value(base, dim) * sine);
    return round_bf16(direct + rotated);
}

void main() {
    uint head = gl_WorkGroupID.x;
    uint lane = gl_LocalInvocationID.x;
    if (head >= HEAD_COUNT) {
        return;
    }

    uint base = head * HEAD_WIDTH;
    for (uint dim = lane * 2u; dim < HEAD_WIDTH; dim += 128u) {
        float lo = rotate(base, dim);
        float hi = rotate(base, dim + 1u);
        output_frame.words[(base + dim) >> 1] =
            (f32_to_bf16(hi) << 16) | f32_to_bf16(lo);
    }
}
