#version 450

layout(local_size_x = 64, local_size_y = 1, local_size_z = 1) in;

layout(set = 0, binding = 0) readonly buffer InputA {
    uint words[];
} input_a;

layout(set = 0, binding = 1) readonly buffer InputB {
    uint words[];
} input_b;

layout(set = 0, binding = 2) buffer OutputFrame {
    uint words[];
} output_frame;

const uint WORD_COUNT = 512u;

float bf16_to_f32(uint value) {
    return uintBitsToFloat((value & 0xffffu) << 16);
}

uint f32_to_bf16(float value) {
    uint bits = floatBitsToUint(value);
    uint lsb = (bits >> 16) & 1u;
    uint rounding_bias = 0x7fffu + lsb;
    return (bits + rounding_bias) >> 16;
}

void main() {
    for (uint word_index = gl_LocalInvocationID.x; word_index < WORD_COUNT; word_index += 64u) {
        uint a = input_a.words[word_index];
        uint b = input_b.words[word_index];
        float a_lo = bf16_to_f32(a & 0xffffu);
        float a_hi = bf16_to_f32(a >> 16);
        float b_lo = bf16_to_f32(b & 0xffffu);
        float b_hi = bf16_to_f32(b >> 16);
        output_frame.words[word_index] =
            (f32_to_bf16(a_hi + b_hi) << 16) | f32_to_bf16(a_lo + b_lo);
    }
}
