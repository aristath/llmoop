#version 450

#extension GL_KHR_shader_subgroup_basic : require
#extension GL_KHR_shader_subgroup_arithmetic : require

layout(local_size_x = 64, local_size_y = 1, local_size_z = 1) in;

layout(set = 0, binding = 0) readonly buffer InputFrame { uint words[]; } input_frame;
layout(set = 0, binding = 1) buffer OutputFrame { uint words[]; } output_frame;
layout(set = 0, binding = 2) readonly buffer GateWeight { uint words[]; } gate_weight;
layout(set = 0, binding = 3) readonly buffer GateScaleInv { uint words[]; } gate_scale_inv;
layout(set = 0, binding = 4) readonly buffer UpWeight { uint words[]; } up_weight;
layout(set = 0, binding = 5) readonly buffer UpScaleInv { uint words[]; } up_scale_inv;

const uint BLOCK_ROWS = {{BLOCK_ROWS}}u;
const uint BLOCK_COLUMNS = {{BLOCK_COLUMNS}}u;
const uint INPUT_SIZE = {{INPUT_SIZE}}u;
const uint OUTPUT_SIZE = {{OUTPUT_SIZE}}u;
const uint OUTPUT_WORDS = (OUTPUT_SIZE + 1u) / 2u;
const uint SCALE_COLUMNS = (INPUT_SIZE + BLOCK_COLUMNS - 1u) / BLOCK_COLUMNS;

shared float subgroup_gate_lo[64];
shared float subgroup_gate_hi[64];
shared float subgroup_up_lo[64];
shared float subgroup_up_hi[64];

float bf16_to_f32(uint value) {
    return uintBitsToFloat((value & 0xffffu) << 16);
}

float read_input_bf16(uint index) {
    uint pair = input_frame.words[index >> 1u];
    return bf16_to_f32(pair >> ((index & 1u) * 16u));
}

vec4 read_input_bf16x4(uint column) {
    uint lo = input_frame.words[column >> 1u];
    uint hi = input_frame.words[(column >> 1u) + 1u];
    return vec4(
        bf16_to_f32(lo),
        bf16_to_f32(lo >> 16u),
        bf16_to_f32(hi),
        bf16_to_f32(hi >> 16u)
    );
}

float read_gate_scale_bf16(uint index) {
    uint pair = gate_scale_inv.words[index >> 1u];
    return bf16_to_f32(pair >> ((index & 1u) * 16u));
}

float read_up_scale_bf16(uint index) {
    uint pair = up_scale_inv.words[index >> 1u];
    return bf16_to_f32(pair >> ((index & 1u) * 16u));
}

float fp8_e4m3_to_f32(uint value) {
    uint bits = value & 0xffu;
    uint exponent = (bits >> 3u) & 0x0fu;
    uint mantissa = bits & 0x07u;
    if (exponent == 0u) {
        float subnormal = float(mantissa) * 0.001953125;
        return (bits & 0x80u) != 0u ? -subnormal : subnormal;
    }
    return uintBitsToFloat(
        ((bits & 0x80u) << 24u)
        | ((exponent + 120u) << 23u)
        | (mantissa << 20u)
    );
}

vec4 fp8_e4m3x4_to_f32(uint packed) {
    return vec4(
        fp8_e4m3_to_f32(packed),
        fp8_e4m3_to_f32(packed >> 8u),
        fp8_e4m3_to_f32(packed >> 16u),
        fp8_e4m3_to_f32(packed >> 24u)
    );
}

float read_gate_weight(uint row, uint column) {
    uint index = row * INPUT_SIZE + column;
    uint packed = gate_weight.words[index >> 2u];
    float value = fp8_e4m3_to_f32(packed >> ((index & 3u) * 8u));
    uint scale_index = (row / BLOCK_ROWS) * SCALE_COLUMNS + column / BLOCK_COLUMNS;
    return value * read_gate_scale_bf16(scale_index);
}

float read_up_weight(uint row, uint column) {
    uint index = row * INPUT_SIZE + column;
    uint packed = up_weight.words[index >> 2u];
    float value = fp8_e4m3_to_f32(packed >> ((index & 3u) * 8u));
    uint scale_index = (row / BLOCK_ROWS) * SCALE_COLUMNS + column / BLOCK_COLUMNS;
    return value * read_up_scale_bf16(scale_index);
}

uint f32_to_bf16(float value) {
    uint bits = floatBitsToUint(value);
    uint lsb = (bits >> 16u) & 1u;
    return (bits + 0x7fffu + lsb) >> 16u;
}

float round_bf16(float value) {
    return bf16_to_f32(f32_to_bf16(value));
}

float rounded_silu(float value) {
    return round_bf16(value / (1.0 + exp(-value)));
}

void write_result(
    uint word_index,
    uint hi_row,
    float gate_lo,
    float gate_hi,
    float up_lo,
    float up_hi
) {
    uint lo = f32_to_bf16(rounded_silu(round_bf16(gate_lo)) * round_bf16(up_lo));
    uint hi = hi_row < OUTPUT_SIZE
        ? f32_to_bf16(rounded_silu(round_bf16(gate_hi)) * round_bf16(up_hi))
        : 0u;
    output_frame.words[word_index] = (hi << 16u) | lo;
}

void main() {
    uint word_index = gl_WorkGroupID.x;
    uint lane = gl_LocalInvocationID.x;
    uint lo_row = word_index * 2u;
    uint hi_row = lo_row + 1u;
    float gate_lo = 0.0;
    float gate_hi = 0.0;
    float up_lo = 0.0;
    float up_hi = 0.0;

    if (word_index < OUTPUT_WORDS) {
        if ((INPUT_SIZE % 4u) == 0u && (BLOCK_ROWS % 2u) == 0u && (BLOCK_COLUMNS % 4u) == 0u) {
            for (uint column = lane * 4u; column < INPUT_SIZE; column += 256u) {
                vec4 input_value = read_input_bf16x4(column);
                uint lo_weight_index = lo_row * INPUT_SIZE + column;
                uint scale_index =
                    (lo_row / BLOCK_ROWS) * SCALE_COLUMNS + column / BLOCK_COLUMNS;
                float gate_scale = read_gate_scale_bf16(scale_index);
                float up_scale = read_up_scale_bf16(scale_index);

                vec4 gate_lo_weight = fp8_e4m3x4_to_f32(
                    gate_weight.words[lo_weight_index >> 2u]
                );
                vec4 up_lo_weight = fp8_e4m3x4_to_f32(
                    up_weight.words[lo_weight_index >> 2u]
                );
                gate_lo = fma(dot(input_value, gate_lo_weight), gate_scale, gate_lo);
                up_lo = fma(dot(input_value, up_lo_weight), up_scale, up_lo);

                if (hi_row < OUTPUT_SIZE) {
                    uint hi_weight_index = hi_row * INPUT_SIZE + column;
                    vec4 gate_hi_weight = fp8_e4m3x4_to_f32(
                        gate_weight.words[hi_weight_index >> 2u]
                    );
                    vec4 up_hi_weight = fp8_e4m3x4_to_f32(
                        up_weight.words[hi_weight_index >> 2u]
                    );
                    gate_hi = fma(dot(input_value, gate_hi_weight), gate_scale, gate_hi);
                    up_hi = fma(dot(input_value, up_hi_weight), up_scale, up_hi);
                }
            }
        } else {
            for (uint column = lane; column < INPUT_SIZE; column += 64u) {
                float input_value = read_input_bf16(column);
                gate_lo = fma(input_value, read_gate_weight(lo_row, column), gate_lo);
                up_lo = fma(input_value, read_up_weight(lo_row, column), up_lo);
                if (hi_row < OUTPUT_SIZE) {
                    gate_hi = fma(input_value, read_gate_weight(hi_row, column), gate_hi);
                    up_hi = fma(input_value, read_up_weight(hi_row, column), up_hi);
                }
            }
        }
    }

    gate_lo = subgroupAdd(gate_lo);
    gate_hi = subgroupAdd(gate_hi);
    up_lo = subgroupAdd(up_lo);
    up_hi = subgroupAdd(up_hi);
    if (gl_NumSubgroups == 1u) {
        if (gl_SubgroupInvocationID == 0u && word_index < OUTPUT_WORDS) {
            write_result(word_index, hi_row, gate_lo, gate_hi, up_lo, up_hi);
        }
        return;
    }

    if (gl_SubgroupInvocationID == 0u) {
        subgroup_gate_lo[gl_SubgroupID] = gate_lo;
        subgroup_gate_hi[gl_SubgroupID] = gate_hi;
        subgroup_up_lo[gl_SubgroupID] = up_lo;
        subgroup_up_hi[gl_SubgroupID] = up_hi;
    }
    barrier();

    if (lane == 0u && word_index < OUTPUT_WORDS) {
        gate_lo = 0.0;
        gate_hi = 0.0;
        up_lo = 0.0;
        up_hi = 0.0;
        for (uint subgroup = 0u; subgroup < gl_NumSubgroups; subgroup++) {
            gate_lo += subgroup_gate_lo[subgroup];
            gate_hi += subgroup_gate_hi[subgroup];
            up_lo += subgroup_up_lo[subgroup];
            up_hi += subgroup_up_hi[subgroup];
        }
        write_result(word_index, hi_row, gate_lo, gate_hi, up_lo, up_hi);
    }
}
