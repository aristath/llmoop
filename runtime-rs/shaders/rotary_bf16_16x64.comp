#version 450

layout(local_size_x = 64, local_size_y = 1, local_size_z = 1) in;

layout(push_constant) uniform StreamControl {
    uint stream_tick_lo;
    uint stream_tick_hi;
    uint control_flags;
    uint dynamic_state_capacity_activations;
} control;

layout(set = 0, binding = 0) readonly buffer InputFrame {
    uint words[];
} input_frame;

layout(set = 0, binding = 1) buffer OutputFrame {
    uint words[];
} output_frame;

const uint HEAD_COUNT = 16u;
const uint HEAD_WIDTH = 64u;
const float ROPE_THETA = 1000000.0;

float bf16_to_f32(uint value) {
    return uintBitsToFloat((value & 0xffffu) << 16);
}

uint f32_to_bf16(float value) {
    uint bits = floatBitsToUint(value);
    uint lsb = (bits >> 16) & 1u;
    uint rounding_bias = 0x7fffu + lsb;
    return (bits + rounding_bias) >> 16;
}

float read_input(uint index) {
    uint packed = input_frame.words[index >> 1];
    uint value = ((index & 1u) == 0u) ? (packed & 0xffffu) : (packed >> 16);
    return bf16_to_f32(value);
}

float rotate_value(uint base, uint dim) {
    if (dim < (HEAD_WIDTH / 2u)) {
        return -read_input(base + dim + (HEAD_WIDTH / 2u));
    }
    return read_input(base + dim - (HEAD_WIDTH / 2u));
}

float rope_angle(uint dim) {
    uint pair_dim = dim % (HEAD_WIDTH / 2u);
    float inv_freq = pow(ROPE_THETA, -float(pair_dim) / float(HEAD_WIDTH / 2u));
    return float(control.stream_tick_lo) * inv_freq;
}

void main() {
    if (gl_GlobalInvocationID.x != 0u) {
        return;
    }

    for (uint head = 0u; head < HEAD_COUNT; head = head + 1u) {
        uint base = head * HEAD_WIDTH;
        for (uint dim = 0u; dim < HEAD_WIDTH; dim = dim + 2u) {
            float angle_lo = rope_angle(dim);
            float angle_hi = rope_angle(dim + 1u);
            float lo = (read_input(base + dim) * cos(angle_lo))
                + (rotate_value(base, dim) * sin(angle_lo));
            float hi = (read_input(base + dim + 1u) * cos(angle_hi))
                + (rotate_value(base, dim + 1u) * sin(angle_hi));
            output_frame.words[(base + dim) >> 1] =
                (f32_to_bf16(hi) << 16) | f32_to_bf16(lo);
        }
    }
}
