#version 450

#extension GL_KHR_shader_subgroup_basic : require
#extension GL_KHR_shader_subgroup_arithmetic : require

layout(local_size_x = 64, local_size_y = 1, local_size_z = 1) in;

layout(set = 0, binding = 0) readonly buffer InputFrames { uint words[]; } input_frames;
layout(set = 0, binding = 1) readonly buffer ResidualFrames { uint words[]; } residual_frames;
layout(set = 0, binding = 2) buffer OutputFrames { uint words[]; } output_frames;
layout(set = 0, binding = 3) readonly buffer Weight { uint words[]; } weight;

layout(push_constant) uniform BatchControl { uint batch_width; } batch_control;

const uint BATCH_TILE_WIDTH = {{BATCH_TILE_WIDTH}}u;
const uint INPUT_SIZE = {{INPUT_SIZE}}u;
const uint OUTPUT_SIZE = {{OUTPUT_SIZE}}u;
const uint INPUT_WORDS = INPUT_SIZE / 2u;
const uint OUTPUT_WORDS = OUTPUT_SIZE / 2u;

shared float subgroup_lo[BATCH_TILE_WIDTH][64];
shared float subgroup_hi[BATCH_TILE_WIDTH][64];

float bf16_to_f32(uint value) { return uintBitsToFloat((value & 0xffffu) << 16); }

uint f32_to_bf16(float value) {
    uint bits = floatBitsToUint(value);
    uint lsb = (bits >> 16) & 1u;
    return (bits + 0x7fffu + lsb) >> 16;
}

float rounded_bf16(float value) { return bf16_to_f32(f32_to_bf16(value)); }

uint read_weight(uint output_word, uint column_word, uint row_offset) {
    uint index = (((output_word * 2u) + row_offset) * INPUT_WORDS) + column_word;
    return weight.words[index];
}

void write_result(uint batch_index, uint output_word, float lo, float hi) {
    uint index = batch_index * OUTPUT_WORDS + output_word;
    uint residual = residual_frames.words[index];
    uint packed_lo = f32_to_bf16(rounded_bf16(lo) + bf16_to_f32(residual));
    uint packed_hi = f32_to_bf16(rounded_bf16(hi) + bf16_to_f32(residual >> 16u));
    output_frames.words[index] = (packed_hi << 16u) | packed_lo;
}

void main() {
    uint output_word = gl_WorkGroupID.x;
    uint batch_start = gl_WorkGroupID.y * BATCH_TILE_WIDTH;
    uint lane = gl_LocalInvocationID.x;
    if (output_word >= OUTPUT_WORDS) return;

    float lo_sum[BATCH_TILE_WIDTH];
    float hi_sum[BATCH_TILE_WIDTH];
    for (uint batch_lane = 0u; batch_lane < BATCH_TILE_WIDTH; batch_lane++) {
        lo_sum[batch_lane] = 0.0;
        hi_sum[batch_lane] = 0.0;
    }
    for (uint column_word = lane; column_word < INPUT_WORDS; column_word += 64u) {
        uint lo_weight = read_weight(output_word, column_word, 0u);
        uint hi_weight = read_weight(output_word, column_word, 1u);
        float lo_weight_lo = bf16_to_f32(lo_weight);
        float lo_weight_hi = bf16_to_f32(lo_weight >> 16u);
        float hi_weight_lo = bf16_to_f32(hi_weight);
        float hi_weight_hi = bf16_to_f32(hi_weight >> 16u);
        for (uint batch_lane = 0u; batch_lane < BATCH_TILE_WIDTH; batch_lane++) {
            uint batch_index = batch_start + batch_lane;
            if (batch_index >= batch_control.batch_width) continue;
            uint input_pair = input_frames.words[batch_index * INPUT_WORDS + column_word];
            float input_lo = bf16_to_f32(input_pair);
            float input_hi = bf16_to_f32(input_pair >> 16u);
            lo_sum[batch_lane] = fma(input_lo, lo_weight_lo, lo_sum[batch_lane]);
            lo_sum[batch_lane] = fma(input_hi, lo_weight_hi, lo_sum[batch_lane]);
            hi_sum[batch_lane] = fma(input_lo, hi_weight_lo, hi_sum[batch_lane]);
            hi_sum[batch_lane] = fma(input_hi, hi_weight_hi, hi_sum[batch_lane]);
        }
    }

    for (uint batch_lane = 0u; batch_lane < BATCH_TILE_WIDTH; batch_lane++) {
        lo_sum[batch_lane] = subgroupAdd(lo_sum[batch_lane]);
        hi_sum[batch_lane] = subgroupAdd(hi_sum[batch_lane]);
    }
    if (gl_NumSubgroups == 1u) {
        if (gl_SubgroupInvocationID == 0u) {
            for (uint batch_lane = 0u; batch_lane < BATCH_TILE_WIDTH; batch_lane++) {
                uint batch_index = batch_start + batch_lane;
                if (batch_index < batch_control.batch_width) {
                    write_result(batch_index, output_word, lo_sum[batch_lane], hi_sum[batch_lane]);
                }
            }
        }
        return;
    }
    if (gl_SubgroupInvocationID == 0u) {
        for (uint batch_lane = 0u; batch_lane < BATCH_TILE_WIDTH; batch_lane++) {
            subgroup_lo[batch_lane][gl_SubgroupID] = lo_sum[batch_lane];
            subgroup_hi[batch_lane][gl_SubgroupID] = hi_sum[batch_lane];
        }
    }
    barrier();
    if (lane == 0u) {
        for (uint batch_lane = 0u; batch_lane < BATCH_TILE_WIDTH; batch_lane++) {
            uint batch_index = batch_start + batch_lane;
            if (batch_index >= batch_control.batch_width) continue;
            float lo_total = 0.0;
            float hi_total = 0.0;
            for (uint subgroup = 0u; subgroup < gl_NumSubgroups; subgroup++) {
                lo_total += subgroup_lo[batch_lane][subgroup];
                hi_total += subgroup_hi[batch_lane][subgroup];
            }
            write_result(batch_index, output_word, lo_total, hi_total);
        }
    }
}
