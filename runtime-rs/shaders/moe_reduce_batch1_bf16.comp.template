#version 450

layout(local_size_x = 64, local_size_y = 1, local_size_z = 1) in;

layout(set = 0, binding = 0) readonly buffer ExpertOutputs { uint words[]; } expert_outputs;
layout(set = 0, binding = 1) buffer OutputFrames { uint words[]; } output_frames;

layout(push_constant) uniform BatchControl { uint batch_width; } batch_control;

const uint HIDDEN_SIZE = {{HIDDEN_SIZE}}u;
const uint EXPERTS_PER_TOKEN = {{EXPERTS_PER_TOKEN}}u;
const uint HIDDEN_WORDS = HIDDEN_SIZE / 2u;

float bf16_to_f32(uint value) {
    return uintBitsToFloat((value & 0xffffu) << 16);
}

uint f32_to_bf16(float value) {
    uint bits = floatBitsToUint(value);
    uint lsb = (bits >> 16) & 1u;
    return (bits + 0x7fffu + lsb) >> 16;
}

float add_bf16(float left, float right) {
    return bf16_to_f32(f32_to_bf16(left + right));
}

void main() {
    uint batch_index = gl_WorkGroupID.y;
    if (batch_index >= batch_control.batch_width) {
        return;
    }
    uint input_offset = batch_index * EXPERTS_PER_TOKEN * HIDDEN_WORDS;
    uint output_offset = batch_index * HIDDEN_WORDS;
    for (uint word = gl_LocalInvocationID.x; word < HIDDEN_WORDS; word += 64u) {
        float lo = 0.0;
        float hi = 0.0;
        for (uint route = 0u; route < EXPERTS_PER_TOKEN; route++) {
            uint contribution = expert_outputs.words[
                input_offset + route * HIDDEN_WORDS + word
            ];
            lo = add_bf16(lo, bf16_to_f32(contribution));
            hi = add_bf16(hi, bf16_to_f32(contribution >> 16u));
        }
        output_frames.words[output_offset + word] =
            (f32_to_bf16(hi) << 16u) | f32_to_bf16(lo);
    }
}
